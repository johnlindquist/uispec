{
  "$format": "uxspec-compiled",
  "$version": "0.2",
  "initial": "loading",
  "contextSchema": {},
  "eventSchema": {},
  "states": {
    "loading": {
      "path": "loading",
      "visual": {
        "$description": "Centered spinner over black background while media loads",
        "container": {
          "layout": "layer",
          "size": {
            "width": "fill",
            "height": "fill"
          },
          "background": "#000000"
        },
        "slots": {
          "center": [
            {
              "type": "icon",
              "icon": "Loader2",
              "size": {
                "value": 48,
                "unit": "px"
              },
              "color": "rgba(255, 255, 255, 0.7)",
              "animation": "spinner"
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "LOADED",
          "target": "ready.paused",
          "guard": null,
          "actions": []
        },
        {
          "event": "LOAD_ERROR",
          "target": "error",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "ready.paused": {
      "path": "ready.paused",
      "visual": {
        "$description": "Video paused — play button shows Play icon, large centered play overlay visible",
        "container": {
          "layout": "layer",
          "size": {
            "width": "fill",
            "height": "fill"
          },
          "background": "#000000"
        },
        "slots": {
          "center": [
            {
              "type": "button",
              "name": "big-play",
              "size": {
                "width": {
                  "value": 64,
                  "unit": "px"
                },
                "height": {
                  "value": 64,
                  "unit": "px"
                }
              },
              "cornerRadius": 9999,
              "style": {
                "background": "rgba(0,0,0,0.6)",
                "color": "#ffffff",
                "iconSize": {
                  "value": 28,
                  "unit": "px"
                }
              },
              "icon": "Play",
              "command": "play"
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "CONTROLS_IDLE",
          "target": "ready.controlsHidden",
          "guard": null,
          "actions": []
        },
        {
          "event": "MOUSE_MOVE",
          "target": "ready.controlsVisible",
          "guard": null,
          "actions": []
        },
        {
          "event": "ERROR",
          "target": "error",
          "guard": null,
          "actions": []
        },
        {
          "event": "PLAY",
          "target": "ready.playing",
          "guard": null,
          "actions": []
        },
        {
          "event": "SEEK",
          "target": "ready.paused",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "ready.playing": {
      "path": "ready.playing",
      "visual": {
        "$description": "Video playing — play button shows Pause icon, no center overlay",
        "container": {
          "layout": "layer",
          "size": {
            "width": "fill",
            "height": "fill"
          },
          "background": "#000000"
        },
        "slots": {
          "center": []
        }
      },
      "transitions": [
        {
          "event": "CONTROLS_IDLE",
          "target": "ready.controlsHidden",
          "guard": null,
          "actions": []
        },
        {
          "event": "MOUSE_MOVE",
          "target": "ready.controlsVisible",
          "guard": null,
          "actions": []
        },
        {
          "event": "ERROR",
          "target": "error",
          "guard": null,
          "actions": []
        },
        {
          "event": "PAUSE",
          "target": "ready.paused",
          "guard": null,
          "actions": []
        },
        {
          "event": "ENDED",
          "target": "ready.ended",
          "guard": null,
          "actions": []
        },
        {
          "event": "BUFFERING",
          "target": "ready.buffering",
          "guard": null,
          "actions": []
        },
        {
          "event": "SEEK",
          "target": "ready.playing",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "ready.buffering": {
      "path": "ready.buffering",
      "visual": {
        "$description": "Playback stalled — center spinner, play button shows Pause icon (still 'playing' intent)",
        "container": {
          "layout": "layer",
          "size": {
            "width": "fill",
            "height": "fill"
          },
          "background": "#000000"
        },
        "slots": {
          "center": [
            {
              "type": "icon",
              "icon": "Loader2",
              "size": {
                "value": 48,
                "unit": "px"
              },
              "color": "#ffffff",
              "animation": "spinner"
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "CONTROLS_IDLE",
          "target": "ready.controlsHidden",
          "guard": null,
          "actions": []
        },
        {
          "event": "MOUSE_MOVE",
          "target": "ready.controlsVisible",
          "guard": null,
          "actions": []
        },
        {
          "event": "ERROR",
          "target": "error",
          "guard": null,
          "actions": []
        },
        {
          "event": "BUFFER_FULL",
          "target": "ready.playing",
          "guard": null,
          "actions": []
        },
        {
          "event": "PAUSE",
          "target": "ready.paused",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "ready.ended": {
      "path": "ready.ended",
      "visual": {
        "$description": "Video ended — center replay button, seek bar at 100%",
        "container": {
          "layout": "layer",
          "size": {
            "width": "fill",
            "height": "fill"
          },
          "background": "#000000"
        },
        "slots": {
          "center": [
            {
              "type": "button",
              "name": "replay",
              "size": {
                "width": {
                  "value": 64,
                  "unit": "px"
                },
                "height": {
                  "value": 64,
                  "unit": "px"
                }
              },
              "cornerRadius": 9999,
              "style": {
                "background": "rgba(0,0,0,0.6)",
                "color": "#ffffff",
                "iconSize": {
                  "value": 28,
                  "unit": "px"
                }
              },
              "icon": "RotateCcw",
              "command": "replay"
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "CONTROLS_IDLE",
          "target": "ready.controlsHidden",
          "guard": null,
          "actions": []
        },
        {
          "event": "MOUSE_MOVE",
          "target": "ready.controlsVisible",
          "guard": null,
          "actions": []
        },
        {
          "event": "ERROR",
          "target": "error",
          "guard": null,
          "actions": []
        },
        {
          "event": "REPLAY",
          "target": "ready.playing",
          "guard": null,
          "actions": []
        },
        {
          "event": "SEEK",
          "target": "ready.paused",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "ready.controlsVisible": {
      "path": "ready.controlsVisible",
      "visual": {
        "$description": "Controls bar visible with controls-show animation",
        "container": {
          "layout": "layer",
          "size": {
            "width": "fill",
            "height": "fill"
          },
          "background": "#000000"
        },
        "slots": {
          "video": [
            {
              "type": "group",
              "name": "video-viewport",
              "layout": "layer",
              "size": {
                "width": "fill",
                "height": "fill"
              }
            }
          ],
          "controls": [
            {
              "type": "group",
              "name": "controls-bar",
              "layout": "stack-v",
              "gap": 8,
              "size": {
                "width": "fill"
              },
              "padding": {
                "horizontal": 16,
                "vertical": 8
              },
              "background": "linear-gradient(transparent, rgba(0,0,0,0.8))",
              "children": [
                {
                  "$description": "Horizontal seek/progress bar with buffered range, played range, and draggable thumb",
                  "type": "group",
                  "name": "seek-bar",
                  "layout": "layer",
                  "size": {
                    "width": "fill",
                    "height": {
                      "value": 4,
                      "unit": "px"
                    }
                  },
                  "cornerRadius": 9999,
                  "interactions": {
                    "hover": {
                      "height": {
                        "value": 6,
                        "unit": "px"
                      }
                    }
                  },
                  "children": [
                    {
                      "type": "shape",
                      "name": "track",
                      "shape": "rectangle",
                      "size": {
                        "width": "fill",
                        "height": "fill"
                      },
                      "fill": "rgba(255, 255, 255, 0.2)",
                      "cornerRadius": 9999
                    },
                    {
                      "type": "shape",
                      "name": "buffered",
                      "shape": "rectangle",
                      "size": {
                        "height": "fill"
                      },
                      "fill": "rgba(255, 255, 255, 0.4)",
                      "cornerRadius": 9999,
                      "dynamic": [
                        {
                          "property": "width",
                          "expr": [
                            "*",
                            [
                              "var",
                              "bufferedFraction"
                            ],
                            100
                          ],
                          "unit": "%"
                        }
                      ]
                    },
                    {
                      "type": "shape",
                      "name": "played",
                      "shape": "rectangle",
                      "size": {
                        "height": "fill"
                      },
                      "fill": "#ff4d4f",
                      "cornerRadius": 9999,
                      "dynamic": [
                        {
                          "property": "width",
                          "expr": [
                            "*",
                            [
                              "var",
                              "playedFraction"
                            ],
                            100
                          ],
                          "unit": "%"
                        }
                      ]
                    },
                    {
                      "type": "shape",
                      "name": "thumb",
                      "shape": "circle",
                      "size": {
                        "value": 12,
                        "unit": "px"
                      },
                      "fill": "#ff4d4f",
                      "conditional": "hovering || dragging",
                      "dynamic": [
                        {
                          "property": "left",
                          "expr": [
                            "*",
                            [
                              "var",
                              "playedFraction"
                            ],
                            100
                          ],
                          "unit": "%"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "group",
                  "name": "transport",
                  "layout": "stack-h",
                  "align": "center",
                  "justify": "space-between",
                  "children": [
                    {
                      "type": "group",
                      "name": "left-controls",
                      "layout": "stack-h",
                      "align": "center",
                      "gap": 4,
                      "children": [
                        {
                          "$description": "Control bar icon button",
                          "type": "button",
                          "size": {
                            "width": {
                              "value": 36,
                              "unit": "px"
                            },
                            "height": {
                              "value": 36,
                              "unit": "px"
                            }
                          },
                          "cornerRadius": 4,
                          "style": {
                            "color": "#ffffff",
                            "background": "transparent",
                            "iconSize": {
                              "value": 20,
                              "unit": "px"
                            }
                          },
                          "interactions": {
                            "hover": {
                              "background": "rgba(255,255,255,0.1)"
                            },
                            "press": {
                              "scale": 0.92
                            }
                          },
                          "name": "play-pause",
                          "icon": "Play",
                          "shortcutKey": "Space"
                        },
                        {
                          "$description": "Control bar icon button",
                          "type": "button",
                          "size": {
                            "width": {
                              "value": 36,
                              "unit": "px"
                            },
                            "height": {
                              "value": 36,
                              "unit": "px"
                            }
                          },
                          "cornerRadius": 4,
                          "style": {
                            "color": "#ffffff",
                            "background": "transparent",
                            "iconSize": {
                              "value": 20,
                              "unit": "px"
                            }
                          },
                          "interactions": {
                            "hover": {
                              "background": "rgba(255,255,255,0.1)"
                            },
                            "press": {
                              "scale": 0.92
                            }
                          },
                          "name": "skip-back",
                          "icon": "SkipBack",
                          "shortcutKey": "ArrowLeft"
                        },
                        {
                          "$description": "Control bar icon button",
                          "type": "button",
                          "size": {
                            "width": {
                              "value": 36,
                              "unit": "px"
                            },
                            "height": {
                              "value": 36,
                              "unit": "px"
                            }
                          },
                          "cornerRadius": 4,
                          "style": {
                            "color": "#ffffff",
                            "background": "transparent",
                            "iconSize": {
                              "value": 20,
                              "unit": "px"
                            }
                          },
                          "interactions": {
                            "hover": {
                              "background": "rgba(255,255,255,0.1)"
                            },
                            "press": {
                              "scale": 0.92
                            }
                          },
                          "name": "skip-forward",
                          "icon": "SkipForward",
                          "shortcutKey": "ArrowRight"
                        },
                        {
                          "$description": "Vertical or horizontal volume slider with mute toggle",
                          "type": "group",
                          "layout": "stack-h",
                          "align": "center",
                          "gap": 4,
                          "children": [
                            {
                              "type": "button",
                              "name": "mute-toggle",
                              "size": {
                                "width": {
                                  "value": 36,
                                  "unit": "px"
                                },
                                "height": {
                                  "value": 36,
                                  "unit": "px"
                                }
                              },
                              "style": {
                                "color": "#ffffff",
                                "background": "transparent"
                              },
                              "dynamic": [
                                {
                                  "property": "icon",
                                  "expr": [
                                    "if",
                                    [
                                      "var",
                                      "muted"
                                    ],
                                    "VolumeX",
                                    [
                                      "if",
                                      [
                                        "<",
                                        [
                                          "var",
                                          "volume"
                                        ],
                                        0.5
                                      ],
                                      "Volume1",
                                      "Volume2"
                                    ]
                                  ]
                                }
                              ],
                              "command": "toggleMute"
                            },
                            {
                              "type": "group",
                              "name": "volume-track",
                              "layout": "layer",
                              "size": {
                                "width": {
                                  "value": 60,
                                  "unit": "px"
                                },
                                "height": {
                                  "value": 4,
                                  "unit": "px"
                                }
                              },
                              "cornerRadius": 9999,
                              "children": [
                                {
                                  "type": "shape",
                                  "name": "track-bg",
                                  "shape": "rectangle",
                                  "size": {
                                    "width": "fill",
                                    "height": "fill"
                                  },
                                  "fill": "rgba(255, 255, 255, 0.2)",
                                  "cornerRadius": 9999
                                },
                                {
                                  "type": "shape",
                                  "name": "volume-fill",
                                  "shape": "rectangle",
                                  "size": {
                                    "height": "fill"
                                  },
                                  "fill": "#ffffff",
                                  "cornerRadius": 9999,
                                  "dynamic": [
                                    {
                                      "property": "width",
                                      "expr": [
                                        "*",
                                        [
                                          "if",
                                          [
                                            "var",
                                            "muted"
                                          ],
                                          0,
                                          [
                                            "var",
                                            "volume"
                                          ]
                                        ],
                                        100
                                      ],
                                      "unit": "%"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "name": "time-display",
                          "dynamic": [
                            {
                              "property": "content",
                              "expr": [
                                "var",
                                "timeDisplay"
                              ]
                            }
                          ],
                          "style": {
                            "fontSize": 11,
                            "fontWeight": 400,
                            "color": "rgba(255, 255, 255, 0.7)",
                            "fontVariantNumeric": "tabular-nums"
                          }
                        }
                      ]
                    },
                    {
                      "type": "group",
                      "name": "right-controls",
                      "layout": "stack-h",
                      "align": "center",
                      "gap": 4,
                      "children": [
                        {
                          "$description": "Control bar icon button",
                          "type": "button",
                          "size": {
                            "width": {
                              "value": 36,
                              "unit": "px"
                            },
                            "height": {
                              "value": 36,
                              "unit": "px"
                            }
                          },
                          "cornerRadius": 4,
                          "style": {
                            "color": "#ffffff",
                            "background": "transparent",
                            "iconSize": {
                              "value": 20,
                              "unit": "px"
                            }
                          },
                          "interactions": {
                            "hover": {
                              "background": "rgba(255,255,255,0.1)"
                            },
                            "press": {
                              "scale": 0.92
                            }
                          },
                          "name": "pip",
                          "icon": "PictureInPicture2",
                          "shortcutKey": "p"
                        },
                        {
                          "$description": "Control bar icon button",
                          "type": "button",
                          "size": {
                            "width": {
                              "value": 36,
                              "unit": "px"
                            },
                            "height": {
                              "value": 36,
                              "unit": "px"
                            }
                          },
                          "cornerRadius": 4,
                          "style": {
                            "color": "#ffffff",
                            "background": "transparent",
                            "iconSize": {
                              "value": 20,
                              "unit": "px"
                            }
                          },
                          "interactions": {
                            "hover": {
                              "background": "rgba(255,255,255,0.1)"
                            },
                            "press": {
                              "scale": 0.92
                            }
                          },
                          "name": "fullscreen",
                          "icon": "Maximize",
                          "shortcutKey": "f"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        "animation": "controls-show"
      },
      "transitions": [
        {
          "event": "CONTROLS_IDLE",
          "target": "ready.controlsHidden",
          "guard": null,
          "actions": []
        },
        {
          "event": "MOUSE_MOVE",
          "target": "ready.controlsVisible",
          "guard": null,
          "actions": []
        },
        {
          "event": "ERROR",
          "target": "error",
          "guard": null,
          "actions": []
        },
        {
          "event": "IDLE_TIMEOUT",
          "target": "ready.controlsHidden",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
