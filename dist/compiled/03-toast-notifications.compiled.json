    "exiting": {
      "path": "exiting",
      "visual": {
        "$description": "Toast slides out to the right, then removed from DOM",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": {
              "value": 356,
              "unit": "px"
            }
          },
          "cornerRadius": 8,
          "background": "#1a1a1a",
          "borderWidth": {
