{
  "$format": "uxspec-compiled",
  "$version": "0.2",
  "initial": "idle",
  "contextSchema": {},
  "eventSchema": {},
  "states": {
    "idle": {
      "path": "idle",
      "visual": {
        "$description": "No toast — not rendered",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": {
              "value": 356,
              "unit": "px"
            }
          },
          "cornerRadius": 8,
          "background": "#1a1a1a",
          "borderWidth": {
            "value": 1,
            "unit": "px"
          },
          "borderColor": "rgba(255, 255, 255, 0.1)",
          "shadow": [
            {
              "x": 0,
              "y": 4,
              "blur": 12,
              "spread": 0,
              "color": "rgba(0,0,0,0.4)"
            }
          ],
          "overflow": "hidden"
        }
      },
      "transitions": [
        {
          "event": "SHOW",
          "target": "entering",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "entering": {
      "path": "entering",
      "visual": {
        "$description": "Toast slides in from the right with spring easing",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": {
              "value": 356,
              "unit": "px"
            }
          },
          "cornerRadius": 8,
          "background": "#1a1a1a",
          "borderWidth": {
            "value": 1,
            "unit": "px"
          },
          "borderColor": "rgba(255, 255, 255, 0.1)",
          "shadow": [
            {
              "x": 0,
              "y": 4,
              "blur": 12,
              "spread": 0,
              "color": "rgba(0,0,0,0.4)"
            }
          ],
          "overflow": "hidden"
        },
        "animation": "slide-in"
      },
      "transitions": [
        {
          "event": "ANIMATION_END",
          "target": "visible.countdown",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "visible.countdown": {
      "path": "visible.countdown",
      "visual": {
        "$description": "Progress bar animating, will auto-dismiss when timer expires",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": {
              "value": 356,
              "unit": "px"
            }
          },
          "cornerRadius": 8,
          "background": "#1a1a1a",
          "borderWidth": {
            "value": 1,
            "unit": "px"
          },
          "borderColor": "rgba(255, 255, 255, 0.1)",
          "shadow": [
            {
              "x": 0,
              "y": 4,
              "blur": 12,
              "spread": 0,
              "color": "rgba(0,0,0,0.4)"
            }
          ],
          "overflow": "hidden"
        },
        "slots": {
          "body": [
            {
              "type": "group",
              "name": "toast-content",
              "layout": "stack-h",
              "align": "start",
              "gap": 12,
              "padding": {
                "value": 16
              },
              "children": [
                {
                  "$description": "Colored icon matching toast severity",
                  "type": "icon",
                  "size": {
                    "value": 16,
                    "unit": "px"
                  },
                  "strokeWidth": 2,
                  "dynamic": [
                    {
                      "property": "icon",
                      "expr": [
                        "if",
                        [
                          "==",
                          [
                            "var",
                            "severity"
                          ],
                          "success"
                        ],
                        "CheckCircle",
                        [
                          "if",
                          [
                            "==",
                            [
                              "var",
                              "severity"
                            ],
                            "error"
                          ],
                          "XCircle",
                          [
                            "if",
                            [
                              "==",
                              [
                                "var",
                                "severity"
                              ],
                              "warning"
                            ],
                            "AlertTriangle",
                            "Info"
                          ]
                        ]
                      ]
                    },
                    {
                      "property": "color",
                      "expr": [
                        "if",
                        [
                          "==",
                          [
                            "var",
                            "severity"
                          ],
                          "success"
                        ],
                        "#52c41a",
                        [
                          "if",
                          [
                            "==",
                            [
                              "var",
                              "severity"
                            ],
                            "error"
                          ],
                          "#ee5555",
                          [
                            "if",
                            [
                              "==",
                              [
                                "var",
                                "severity"
                              ],
                              "warning"
                            ],
                            "#f5a623",
                            "#0070f3"
                          ]
                        ]
                      ]
                    }
                  ]
                },
                {
                  "type": "group",
                  "name": "text-content",
                  "layout": "stack-v",
                  "gap": 4,
                  "size": {
                    "width": "fill"
                  },
                  "children": [
                    {
                      "type": "text",
                      "bind": "title",
                      "style": {
                        "fontSize": 14,
                        "fontWeight": 500,
                        "color": "#ffffff"
                      }
                    },
                    {
                      "type": "text",
                      "bind": "message",
                      "style": {
                        "fontSize": 12,
                        "color": "rgba(255, 255, 255, 0.6)"
                      }
                    }
                  ]
                },
                {
                  "type": "button",
                  "name": "close",
                  "icon": "X",
                  "iconSize": {
                    "value": 14,
                    "unit": "px"
                  },
                  "size": {
                    "width": {
                      "value": 24,
                      "unit": "px"
                    },
                    "height": {
                      "value": 24,
                      "unit": "px"
                    }
                  },
                  "style": {
                    "color": "rgba(255, 255, 255, 0.6)",
                    "background": "transparent"
                  },
                  "interactions": {
                    "hover": {
                      "color": "#ffffff"
                    }
                  },
                  "command": "dismiss"
                }
              ]
            }
          ],
          "action": [
            {
              "$description": "Optional action button (e.g., 'Undo'). Only rendered when context.action is set.",
              "type": "button",
              "name": "action",
              "bind": "actionLabel",
              "size": {
                "width": "fill",
                "height": {
                  "value": 36,
                  "unit": "px"
                }
              },
              "style": {
                "fontSize": 12,
                "fontWeight": 500,
                "color": "#0070f3",
                "background": "rgba(0, 112, 243, 0.1)",
                "borderTop": "1px solid {color.stroke}"
              },
              "command": "executeAction",
              "conditional": "context.action != null"
            }
          ],
          "progress": [
            {
              "$description": "Thin progress bar at the bottom that shrinks to zero over the auto-dismiss duration",
              "type": "shape",
              "shape": "rectangle",
              "name": "progress-bar",
              "size": {
                "width": "fill",
                "height": {
                  "value": 2,
                  "unit": "px"
                }
              },
              "transformOrigin": "left",
              "dynamic": [
                {
                  "property": "background",
                  "expr": [
                    "if",
                    [
                      "==",
                      [
                        "var",
                        "severity"
                      ],
                      "success"
                    ],
                    "#52c41a",
                    [
                      "if",
                      [
                        "==",
                        [
                          "var",
                          "severity"
                        ],
                        "error"
                      ],
                      "#ee5555",
                      [
                        "if",
                        [
                          "==",
                          [
                            "var",
                            "severity"
                          ],
                          "warning"
                        ],
                        "#f5a623",
                        "#0070f3"
                      ]
                    ]
                  ]
                }
              ],
              "animation": "progress-shrink",
              "conditional": "context.autoDismiss != null"
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "DISMISS",
          "target": "exiting",
          "guard": null,
          "actions": []
        },
        {
          "event": "ACTION",
          "target": "exiting",
          "guard": null,
          "actions": []
        },
        {
          "event": "SWIPE_RIGHT",
          "target": "exiting",
          "guard": null,
          "actions": []
        },
        {
          "event": "TIMER_EXPIRED",
          "target": "exiting",
          "guard": null,
          "actions": []
        },
        {
          "event": "HOVER_START",
          "target": "visible.paused",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "visible.paused": {
      "path": "visible.paused",
      "visual": {
        "$description": "Mouse hovering — progress bar paused, countdown frozen. Toast stays visible indefinitely while hovered.",
        "container": {
          "layout": "stack-v",
