{
  "$format": "uispec-compiled",
  "$version": "0.2",
  "initial": "editing",
  "contextSchema": {},
  "eventSchema": {},
  "states": {
    "editing.pristine": {
      "path": "editing.pristine",
      "visual": {
        "$description": "No fields touched yet — all fields in default state, no errors shown",
        "container": {
          "layout": "layer",
          "align": "center",
          "justify": "center",
          "size": {
            "width": "fill",
            "height": "fill"
          },
          "background": "{color.bg}"
        },
        "slots": {
          "content": [
            {
              "type": "group",
              "name": "form-card",
              "layout": "stack-v",
              "align": "stretch",
              "gap": "{spacing.lg}",
              "size": {
                "width": {
                  "value": 480,
                  "unit": "px"
                }
              },
              "padding": {
                "value": "{spacing.xl}"
              },
              "background": "{color.card}",
              "cornerRadius": "{radius.lg}",
              "borderWidth": {
                "value": 1,
                "unit": "px"
              },
              "borderColor": "{color.stroke}",
              "children": [
                {
                  "type": "text",
                  "content": "form.title",
                  "style": {
                    "fontSize": "{font.size.xl}",
                    "fontWeight": "{font.weight.medium}",
                    "color": "{color.text.primary}"
                  }
                },
                {
                  "type": "text",
                  "content": "form.subtitle",
                  "style": {
                    "fontSize": "{font.size.sm}",
                    "color": "{color.text.secondary}"
                  }
                },
                {
                  "$ref": "field",
                  "name": "fullName",
                  "label": "form.name",
                  "placeholder": "form.namePlaceholder",
                  "inputType": "text",
                  "required": true
                },
                {
                  "$ref": "field",
                  "name": "email",
                  "label": "form.email",
                  "placeholder": "form.emailPlaceholder",
                  "inputType": "email",
                  "required": true,
                  "helperText": "form.emailHelper"
                },
                {
                  "$ref": "field",
                  "name": "subject",
                  "label": "form.subject",
                  "placeholder": "form.subjectPlaceholder",
                  "inputType": "text"
                },
                {
                  "type": "group",
                  "layout": "stack-v",
                  "gap": "{spacing.xs}",
                  "children": [
                    {
                      "$ref": "field",
                      "name": "message",
                      "label": "form.message",
                      "placeholder": "form.messagePlaceholder",
                      "inputType": "textarea",
                      "required": true,
                      "maxLength": 500
                    }
                  ]
                },
                {
                  "type": "button",
                  "name": "submit",
                  "command": "submitForm",
                  "size": {
                    "width": "fill",
                    "height": {
                      "value": 40,
                      "unit": "px"
                    }
                  },
                  "cornerRadius": "{radius.sm}",
                  "style": {
                    "background": "{color.accent}",
                    "fontSize": "{font.size.base}",
                    "fontWeight": "{font.weight.medium}",
                    "color": "{color.text.primary}"
                  },
                  "interactions": {
                    "hover": {
                      "background": "{color.accentHover}"
                    },
                    "disabled": {
                      "opacity": 0.5
                    }
                  },
                  "dynamic": [
                    {
                      "property": "disabled",
                      "expr": [
                        "!",
                        [
                          "var",
                          "formValid"
                        ]
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "FOCUS_FIELD",
          "target": "dirty",
          "guard": null,
          "actions": []
        },
        {
          "event": "TYPE",
          "target": "dirty",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
