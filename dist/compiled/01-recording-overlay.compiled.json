          "gap": 10,
          "cornerRadius": 18,
          "background": "rgba(18, 18, 22, 0.72)",
          "borderWidth": {
            "value": 1,
            "unit": "px"
          },
          "borderColor": "rgba(255, 255, 255, 0.18)",
          "backdropBlur": {
            "value": 6,
            "unit": "px"
          },
          "backdropSaturate": 1.4
        }
      },
      "transitions": [
        {
          "event": "SHOW",
          "target": "recording.active",
          "guard": null,
          "actions": []
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "recording.active": {
      "path": "recording.active",
      "visual": {
        "$description": "Live recording — waveform bars animate with mic levels, timer counts up",
        "container": {
          "layout": "grid",
          "columns": [
            "auto",
            "1fr",
            "auto"
          ],
          "align": "center",
          "size": {
            "width": "fill",
            "height": {
              "value": 36,
              "unit": "px"
            }
          },
          "padding": {
            "vertical": {
              "value": 0,
              "unit": "px"
            },
            "horizontal": 14
          },
          "gap": 10,
          "cornerRadius": 18,
          "background": "rgba(18, 18, 22, 0.72)",
          "borderWidth": {
            "value": 1,
            "unit": "px"
          },
          "borderColor": "rgba(255, 255, 255, 0.18)",
          "backdropBlur": {
            "value": 6,
            "unit": "px"
          },
          "backdropSaturate": 1.4
        },
        "slots": {
          "left": [
            {
              "$description": "Vercel Voice triangle logo, always white",
              "type": "icon",
              "icon": "VercelVoiceLogo",
              "size": {
                "value": 16,
                "unit": "px"
              },
              "color": "#ffffff"
            },
            {
              "$description": "Elapsed recording time in MM:SS, monospace numerals",
              "type": "text",
              "role": "timer",
              "style": {
                "fontSize": 11,
                "fontWeight": 500,
                "color": "rgba(255, 255, 255, 0.5)",
                "fontVariantNumeric": "tabular-nums",
                "whiteSpace": "nowrap"
              }
            }
          ],
          "middle": [
            {
              "type": "group",
              "name": "waveform",
              "layout": "stack-h",
              "align": "end",
              "justify": "center",
              "gap": 4,
              "size": {
                "height": {
                  "value": 20,
                  "unit": "px"
                }
              },
              "clip": true,
              "children": {
                "type": "bar",
                "repeat": 9,
                "size": {
                  "width": {
                    "value": 3,
                    "unit": "px"
                  },
                  "minHeight": {
                    "value": 3,
                    "unit": "px"
                  },
                  "maxHeight": {
                    "value": 18,
                    "unit": "px"
                  }
                },
                "cornerRadius": 1.5,
                "dynamic": [
                  {
                    "property": "height",
                    "expr": [
                      "+",
                      4,
                      [
                        "*",
                        16,
                        [
                          "pow",
                          [
                            "var",
                            "level"
                          ],
                          0.7
                        ]
                      ]
                    ]
                  },
                  {
                    "property": "opacity",
                    "expr": [
                      "max",
                      0.3,
                      [
                        "*",
                        [
                          "var",
                          "level"
                        ],
                        1.5
                      ]
                    ]
                  },
                  {
                    "property": "background",
                    "expr": [
                      "if",
                      [
                        "var",
                        "hasSound"
                      ],
                      "#52c41a",
                      "#ff4d4f"
                    ]
                  }
                ]
              }
            }
          ],
          "right": [
            {
              "$description": "24×24 icon button with hover/press/focus states",
              "type": "button",
              "size": {
                "width": {
                  "value": 24,
                  "unit": "px"
                },
                "height": {
                  "value": 24,
                  "unit": "px"
                }
              },
              "cornerRadius": 4,
              "style": {
                "background": "rgba(255, 255, 255, 0.05)",
                "borderWidth": {
                  "value": 1,
                  "unit": "px"
                },
                "borderColor": "rgba(255, 255, 255, 0.1)",
                "iconSize": {
                  "value": 16,
                  "unit": "px"
                },
                "iconStrokeWidth": 2.5,
                "color": "rgba(255, 255, 255, 0.6)"
              },
              "interactions": {
                "hover": {
                  "color": "#ffffff",
                  "background": "rgba(255, 255, 255, 0.15)",
                  "borderColor": "rgba(255, 255, 255, 0.25)"
                },
                "press": {
                  "scale": 0.95,
                  "background": "rgba(255, 255, 255, 0.2)"
                },
                "focus": {
                  "outlineWidth": {
                    "value": 2,
                    "unit": "px"
                  },
                  "outlineColor": "rgba(255, 255, 255, 0.5)",
                  "outlineOffset": {
                    "value": 1,
                    "unit": "px"
                  }
                }
