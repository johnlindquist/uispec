{
  "$format": "uxspec-compiled",
  "$version": "0.2",
  "initial": "loading",
  "contextSchema": {
    "resourceId": {
      "type": "string",
      "required": true,
      "$description": "URL or route param identifying the resource"
    },
    "loading": {
      "type": "boolean",
      "default": true,
      "$description": "Whether the initial load is in progress"
    },
    "resource": {
      "type": "object",
      "default": null,
      "$description": "The loaded resource object"
    },
    "snapshot": {
      "type": "object",
      "default": null,
      "$description": "Pre-save snapshot for rollback on failure"
    },
    "draftName": {
      "type": "string",
      "default": "",
      "$description": "Editable name field value"
    },
    "draftEmail": {
      "type": "string",
      "default": "",
      "$description": "Editable email field value"
    },
    "saving": {
      "type": "boolean",
      "default": false,
      "$description": "Whether a save request is in flight"
    },
    "saveError": {
      "type": "string",
      "default": null,
      "$description": "Error message from a failed save"
    },
    "loadError": {
      "type": "string",
      "default": null,
      "$description": "Error message from a failed load"
    },
    "toastMessage": {
      "type": "string",
      "default": null,
      "$description": "Current toast text"
    },
    "toastVariant": {
      "type": "string",
      "default": "success",
      "$description": "Toast style: success or error"
    }
  },
  "eventSchema": {
    "LOAD_OK": {
      "source": "network",
      "payload": {
        "resource": {
          "type": "object"
        }
      }
    },
    "LOAD_EMPTY": {
      "source": "network",
      "payload": {}
    },
    "LOAD_ERROR": {
      "source": "network",
      "payload": {
        "message": {
          "type": "string"
        }
      }
    },
    "RETRY": {
      "source": "user",
      "payload": {}
    },
    "EDIT": {
      "source": "user",
      "payload": {}
    },
    "CANCEL_EDIT": {
      "source": "user",
      "payload": {}
    },
    "FIELD_CHANGED": {
      "source": "user",
      "payload": {
        "name": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "SAVE": {
      "source": "user",
      "payload": {}
    },
    "SAVE_OK": {
      "source": "network",
      "payload": {
        "resource": {
          "type": "object"
        }
      }
    },
    "SAVE_ERROR": {
      "source": "network",
      "payload": {
        "message": {
          "type": "string"
        }
      }
    },
    "TOAST_DISMISS": {
      "source": "timer",
      "payload": {}
    },
    "CREATE": {
      "source": "user",
      "payload": {}
    }
  },
  "states": {
    "loading": {
      "path": "loading",
      "visual": {
        "$description": "Skeleton placeholder rows while data loads",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": "fill",
            "minHeight": "fill"
          },
          "padding": {
            "horizontal": 32,
            "vertical": 24
          },
          "background": "#ffffff"
        },
        "animation": "fade-in",
        "slots": {
          "content": [
            {
              "type": "group",
              "name": "skeleton-container",
              "layout": "stack-v",
              "gap": 16,
              "testId": "loading-skeleton",
              "aria": {
                "role": "status",
                "label": "Loading resource",
                "busy": true
              },
              "children": [
                {
                  "$description": "A placeholder skeleton row for loading state",
                  "type": "shape",
                  "shape": "rectangle",
                  "size": {
                    "width": "fill",
                    "height": {
                      "value": 20,
                      "unit": "px"
                    }
                  },
                  "fill": "#f3f4f6",
                  "cornerRadius": 4,
                  "animation": "skeleton-pulse",
                  "aria": {
                    "hidden": true
                  }
                },
                {
                  "$description": "A placeholder skeleton row for loading state",
                  "type": "shape",
                  "shape": "rectangle",
                  "size": {
                    "width": "fill",
                    "height": {
                      "value": 20,
                      "unit": "px"
                    }
                  },
                  "fill": "#f3f4f6",
                  "cornerRadius": 4,
                  "animation": "skeleton-pulse",
                  "aria": {
                    "hidden": true
                  }
                },
                {
                  "$description": "A placeholder skeleton row for loading state",
                  "type": "shape",
                  "shape": "rectangle",
                  "size": {
                    "width": "fill",
                    "height": {
                      "value": 20,
                      "unit": "px"
                    }
                  },
                  "fill": "#f3f4f6",
                  "cornerRadius": 4,
                  "animation": "skeleton-pulse",
                  "aria": {
                    "hidden": true
                  }
                },
                {
                  "$description": "A placeholder skeleton row for loading state",
                  "type": "shape",
                  "shape": "rectangle",
                  "size": {
                    "width": "fill",
                    "height": {
                      "value": 20,
                      "unit": "px"
                    }
                  },
                  "fill": "#f3f4f6",
                  "cornerRadius": 4,
                  "animation": "skeleton-pulse",
                  "aria": {
                    "hidden": true
                  }
                }
              ]
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "LOAD_OK",
          "target": "ready.viewing",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.resource",
              "value": [
                "var",
                "event.resource"
              ]
            },
            {
              "kind": "assign",
              "path": "context.loading",
              "value": false
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_load_ok"
            }
          ]
        },
        {
          "event": "LOAD_EMPTY",
          "target": "empty",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.loading",
              "value": false
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_load_empty"
            }
          ]
        },
        {
          "event": "LOAD_ERROR",
          "target": "error",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.loadError",
              "value": [
                "var",
                "event.message"
              ]
            },
            {
              "kind": "assign",
              "path": "context.loading",
              "value": false
            },
            {
              "kind": "log",
              "level": "error",
              "message": "resource_load_error"
            }
          ]
        }
      ],
      "entry": [
        {
          "kind": "http",
          "request": "loadResource"
        },
        {
          "kind": "log",
          "level": "info",
          "message": "resource_load_start"
        }
      ],
      "exit": [],
      "invoke": []
    },
    "ready.viewing": {
      "path": "ready.viewing",
      "visual": {
        "$description": "Read-only display of resource fields with an Edit button",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": "fill",
            "minHeight": "fill"
          },
          "padding": {
            "horizontal": 32,
            "vertical": 24
          },
          "background": "#ffffff"
        },
        "animation": "fade-in",
        "slots": {
          "content": [
            {
              "type": "group",
              "name": "resource-display",
              "layout": "stack-v",
              "gap": 24,
              "testId": "resource-display",
              "children": [
                {
                  "type": "text",
                  "name": "resource-name",
                  "binding": {
                    "content": [
                      "var",
                      "context.draftName"
                    ]
                  },
                  "style": {
                    "fontSize": 24,
                    "fontWeight": 700,
                    "color": "#111827"
                  },
                  "testId": "resource-name",
                  "aria": {
                    "role": "heading",
                    "level": 1
                  }
                },
                {
                  "type": "text",
                  "name": "resource-email",
                  "binding": {
                    "content": [
                      "var",
                      "context.draftEmail"
                    ]
                  },
                  "style": {
                    "fontSize": 14,
                    "color": "#6b7280"
                  },
                  "testId": "resource-email"
                },
                {
                  "type": "button",
                  "name": "edit-button",
                  "content": "Edit",
                  "onPress": [
                    {
                      "kind": "emit",
                      "event": "EDIT"
                    }
                  ],
                  "style": {
                    "background": "#2563eb",
                    "color": "#ffffff",
                    "cornerRadius": 4,
                    "padding": {
                      "horizontal": 16,
                      "vertical": 8
                    }
                  },
                  "testId": "resource-edit-btn",
                  "aria": {
                    "label": "Edit resource"
                  }
                }
              ]
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "EDIT",
          "target": "ready.editing",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.snapshot",
              "value": [
                "var",
                "context.resource"
              ]
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_edit_start"
            }
          ]
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "ready.editing": {
      "path": "ready.editing",
      "visual": {
        "$description": "Editable form with name and email fields, Save and Cancel buttons",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": "fill",
            "minHeight": "fill"
          },
          "padding": {
            "horizontal": 32,
            "vertical": 24
          },
          "background": "#ffffff"
        },
        "animation": "fade-in",
        "slots": {
          "content": [
            {
              "type": "group",
              "name": "edit-form",
              "layout": "stack-v",
              "gap": 16,
              "testId": "resource-edit-form",
              "aria": {
                "role": "form",
                "label": "Edit resource"
              },
              "children": [
                {
                  "$description": "Labeled form field",
                  "type": "group",
                  "layout": "stack-v",
                  "gap": 4,
                  "children": [
                    {
                      "type": "text",
                      "binding": {
                        "content": "Name"
                      },
                      "style": {
                        "fontSize": 13,
                        "fontWeight": 500,
                        "color": "#6b7280"
                      }
                    },
                    {
                      "type": "input",
                      "binding": {
                        "name": "draftName"
                      },
                      "onChange": [
                        {
                          "kind": "emit",
                          "event": "FIELD_CHANGED"
                        }
                      ],
                      "style": {
                        "height": {
                          "value": 36,
                          "unit": "px"
                        },
                        "padding": {
                          "horizontal": 8
                        },
                        "fontSize": 14,
                        "color": "#111827",
                        "background": "#ffffff",
                        "borderWidth": {
                          "value": 1,
                          "unit": "px"
                        },
                        "borderColor": "#e5e7eb",
                        "cornerRadius": 4
                      },
                      "testId": "field-input"
                    }
                  ],
                  "name": "draftName",
                  "label": "Name",
                  "testId": "edit-name",
                  "aria": {
                    "label": "Resource name"
                  }
                },
                {
                  "$description": "Labeled form field",
                  "type": "group",
                  "layout": "stack-v",
                  "gap": 4,
                  "children": [
                    {
                      "type": "text",
                      "binding": {
                        "content": "Email"
                      },
                      "style": {
                        "fontSize": 13,
                        "fontWeight": 500,
                        "color": "#6b7280"
                      }
                    },
                    {
                      "type": "input",
                      "binding": {
                        "name": "draftEmail"
                      },
                      "onChange": [
                        {
                          "kind": "emit",
                          "event": "FIELD_CHANGED"
                        }
                      ],
                      "style": {
                        "height": {
                          "value": 36,
                          "unit": "px"
                        },
                        "padding": {
                          "horizontal": 8
                        },
                        "fontSize": 14,
                        "color": "#111827",
                        "background": "#ffffff",
                        "borderWidth": {
                          "value": 1,
                          "unit": "px"
                        },
                        "borderColor": "#e5e7eb",
                        "cornerRadius": 4
                      },
                      "testId": "field-input"
                    }
                  ],
                  "name": "draftEmail",
                  "label": "Email",
                  "testId": "edit-email",
                  "aria": {
                    "label": "Resource email"
                  }
                },
                {
                  "type": "group",
                  "name": "form-actions",
                  "layout": "stack-h",
                  "gap": 8,
                  "children": [
                    {
                      "type": "button",
                      "name": "save-button",
                      "content": "Save",
                      "onPress": [
                        {
                          "kind": "emit",
                          "event": "SAVE"
                        }
                      ],
                      "enabledWhen": [
                        "==",
                        [
                          "var",
                          "context.saving"
                        ],
                        false
                      ],
                      "style": {
                        "background": "#2563eb",
                        "color": "#ffffff",
                        "cornerRadius": 4,
                        "padding": {
                          "horizontal": 16,
                          "vertical": 8
                        }
                      },
                      "testId": "resource-save-btn",
                      "aria": {
                        "label": "Save changes"
                      }
                    },
                    {
                      "type": "button",
                      "name": "cancel-button",
                      "content": "Cancel",
                      "onPress": [
                        {
                          "kind": "emit",
                          "event": "CANCEL_EDIT"
                        }
                      ],
                      "enabledWhen": [
                        "==",
                        [
                          "var",
                          "context.saving"
                        ],
                        false
                      ],
                      "style": {
                        "background": "transparent",
                        "color": "#6b7280",
                        "borderWidth": {
                          "value": 1,
                          "unit": "px"
                        },
                        "borderColor": "#e5e7eb",
                        "cornerRadius": 4,
                        "padding": {
                          "horizontal": 16,
                          "vertical": 8
                        }
                      },
                      "testId": "resource-cancel-btn",
                      "aria": {
                        "label": "Cancel editing"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "FIELD_CHANGED",
          "target": "ready.editing",
          "guard": null,
          "actions": [
            {
              "kind": "log",
              "level": "info",
              "message": "resource_field_changed"
            }
          ]
        },
        {
          "event": "SAVE",
          "target": "ready.saving",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.saving",
              "value": true
            },
            {
              "kind": "assign",
              "path": "context.saveError",
              "value": null
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_save_start"
            }
          ]
        },
        {
          "event": "CANCEL_EDIT",
          "target": "ready.viewing",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.resource",
              "value": [
                "var",
                "context.snapshot"
              ]
            },
            {
              "kind": "assign",
              "path": "context.snapshot",
              "value": null
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_edit_cancel"
            }
          ]
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "ready.saving": {
      "path": "ready.saving",
      "visual": {
        "$description": "Save button shows spinner; form fields disabled; optimistic UI shows updated values",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": "fill",
            "minHeight": "fill"
          },
          "padding": {
            "horizontal": 32,
            "vertical": 24
          },
          "background": "#ffffff"
        },
        "animation": "fade-in"
      },
      "transitions": [
        {
          "event": "SAVE_OK",
          "target": "ready.viewing",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.resource",
              "value": [
                "var",
                "event.resource"
              ]
            },
            {
              "kind": "assign",
              "path": "context.saving",
              "value": false
            },
            {
              "kind": "assign",
              "path": "context.snapshot",
              "value": null
            },
            {
              "kind": "assign",
              "path": "context.toastMessage",
              "value": "Changes saved successfully"
            },
            {
              "kind": "assign",
              "path": "context.toastVariant",
              "value": "success"
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_save_ok"
            }
          ]
        },
        {
          "event": "SAVE_ERROR",
          "target": "ready.saveError",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.resource",
              "value": [
                "var",
                "context.snapshot"
              ]
            },
            {
              "kind": "assign",
              "path": "context.saving",
              "value": false
            },
            {
              "kind": "assign",
              "path": "context.saveError",
              "value": [
                "var",
                "event.message"
              ]
            },
            {
              "kind": "log",
              "level": "error",
              "message": "resource_save_error"
            }
          ]
        }
      ],
      "entry": [
        {
          "kind": "http",
          "request": "saveResource"
        }
      ],
      "exit": [],
      "invoke": []
    },
    "ready.saveError": {
      "path": "ready.saveError",
      "visual": {
        "$description": "Inline error banner above form, fields preserved with pre-save values (rollback applied), retry available",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": "fill",
            "minHeight": "fill"
          },
          "padding": {
            "horizontal": 32,
            "vertical": 24
          },
          "background": "#ffffff"
        },
        "animation": "fade-in",
        "slots": {
          "content": [
            {
              "type": "group",
              "name": "save-error-container",
              "layout": "stack-v",
              "gap": 16,
              "testId": "save-error-container",
              "children": [
                {
                  "type": "group",
                  "name": "error-banner",
                  "layout": "stack-h",
                  "align": "center",
                  "gap": 8,
                  "padding": {
                    "horizontal": 16,
                    "vertical": 8
                  },
                  "background": "#fef2f2",
                  "cornerRadius": 4,
                  "testId": "save-error-banner",
                  "aria": {
                    "role": "alert"
                  },
                  "children": [
                    {
                      "type": "icon",
                      "icon": "AlertCircle",
                      "size": {
                        "value": 16,
                        "unit": "px"
                      },
                      "color": "#dc2626"
                    },
                    {
                      "type": "text",
                      "binding": {
                        "content": [
                          "var",
                          "context.saveError"
                        ]
                      },
                      "style": {
                        "fontSize": 13,
                        "color": "#dc2626"
                      }
                    }
                  ]
                },
                {
                  "type": "button",
                  "name": "retry-save",
                  "content": "Retry Save",
                  "onPress": [
                    {
                      "kind": "emit",
                      "event": "SAVE"
                    }
                  ],
                  "style": {
                    "background": "#2563eb",
                    "color": "#ffffff",
                    "cornerRadius": 4,
                    "padding": {
                      "horizontal": 16,
                      "vertical": 8
                    }
                  },
                  "testId": "save-retry-btn",
                  "aria": {
                    "label": "Retry saving changes"
                  }
                }
              ]
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "SAVE",
          "target": "ready.saving",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.saving",
              "value": true
            },
            {
              "kind": "assign",
              "path": "context.saveError",
              "value": null
            }
          ]
        },
        {
          "event": "CANCEL_EDIT",
          "target": "ready.viewing",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.saveError",
              "value": null
            },
            {
              "kind": "assign",
              "path": "context.snapshot",
              "value": null
            }
          ]
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "empty": {
      "path": "empty",
      "visual": {
        "$description": "Zero state — illustration, explanatory text, and a create CTA",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": "fill",
            "minHeight": "fill"
          },
          "padding": {
            "horizontal": 32,
            "vertical": 24
          },
          "background": "#ffffff"
        },
        "animation": "fade-in",
        "slots": {
          "content": [
            {
              "type": "group",
              "name": "empty-state",
              "layout": "stack-v",
              "align": "center",
              "gap": 24,
              "padding": {
                "vertical": 32
              },
              "testId": "empty-state",
              "aria": {
                "role": "status"
              },
              "children": [
                {
                  "type": "icon",
                  "icon": "Inbox",
                  "size": {
                    "value": 64,
                    "unit": "px"
                  },
                  "color": "#9ca3af"
                },
                {
                  "type": "text",
                  "content": "No resources found",
                  "style": {
                    "fontSize": 18,
                    "fontWeight": 500,
                    "color": "#111827"
                  },
                  "testId": "empty-title"
                },
                {
                  "type": "text",
                  "content": "Create your first resource to get started.",
                  "style": {
                    "fontSize": 14,
                    "color": "#6b7280"
                  },
                  "testId": "empty-description"
                },
                {
                  "type": "button",
                  "name": "create-button",
                  "content": "Create Resource",
                  "onPress": [
                    {
                      "kind": "emit",
                      "event": "CREATE"
                    }
                  ],
                  "style": {
                    "background": "#2563eb",
                    "color": "#ffffff",
                    "cornerRadius": 4,
                    "padding": {
                      "horizontal": 24,
                      "vertical": 8
                    }
                  },
                  "testId": "empty-create-btn",
                  "aria": {
                    "label": "Create new resource"
                  }
                }
              ]
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "CREATE",
          "target": "loading",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.loading",
              "value": true
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_create_start"
            }
          ]
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    },
    "error": {
      "path": "error",
      "visual": {
        "$description": "Load error with retry button",
        "container": {
          "layout": "stack-v",
          "size": {
            "width": "fill",
            "minHeight": "fill"
          },
          "padding": {
            "horizontal": 32,
            "vertical": 24
          },
          "background": "#ffffff"
        },
        "animation": "fade-in",
        "slots": {
          "content": [
            {
              "type": "group",
              "name": "error-state",
              "layout": "stack-v",
              "align": "center",
              "gap": 24,
              "padding": {
                "vertical": 32
              },
              "testId": "error-state",
              "aria": {
                "role": "alert"
              },
              "children": [
                {
                  "type": "icon",
                  "icon": "AlertTriangle",
                  "size": {
                    "value": 48,
                    "unit": "px"
                  },
                  "color": "#dc2626"
                },
                {
                  "type": "text",
                  "content": "Failed to load resource",
                  "style": {
                    "fontSize": 18,
                    "fontWeight": 500,
                    "color": "#111827"
                  },
                  "testId": "error-title"
                },
                {
                  "type": "text",
                  "binding": {
                    "content": [
                      "var",
                      "context.loadError"
                    ]
                  },
                  "style": {
                    "fontSize": 14,
                    "color": "#6b7280"
                  },
                  "testId": "error-message"
                },
                {
                  "type": "button",
                  "name": "retry-button",
                  "content": "Retry",
                  "onPress": [
                    {
                      "kind": "emit",
                      "event": "RETRY"
                    }
                  ],
                  "style": {
                    "background": "#2563eb",
                    "color": "#ffffff",
                    "cornerRadius": 4,
                    "padding": {
                      "horizontal": 24,
                      "vertical": 8
                    }
                  },
                  "testId": "error-retry-btn",
                  "aria": {
                    "label": "Retry loading resource"
                  }
                }
              ]
            }
          ]
        }
      },
      "transitions": [
        {
          "event": "RETRY",
          "target": "loading",
          "guard": null,
          "actions": [
            {
              "kind": "assign",
              "path": "context.loading",
              "value": true
            },
            {
              "kind": "assign",
              "path": "context.loadError",
              "value": null
            },
            {
              "kind": "log",
              "level": "info",
              "message": "resource_retry"
            }
          ]
        }
      ],
      "entry": [],
      "exit": [],
      "invoke": []
    }
