{
  "$schema": "https://uispec.dev/0.2/schema.json",
  "$description": "Resource page with fetch, empty state, edit form, optimistic save, rollback, toast, retry, focus management, test IDs, and aria metadata. Proves UISpec can model real app-level concerns end-to-end.",

  "$tokens": {
    "color": {
      "bg":          { "$type": "color", "$value": "#ffffff" },
      "surface":     { "$type": "color", "$value": "#f9fafb" },
      "surfaceAlt":  { "$type": "color", "$value": "#f3f4f6" },
      "stroke":      { "$type": "color", "$value": "#e5e7eb" },
      "text": {
        "primary":   { "$type": "color", "$value": "#111827" },
        "secondary": { "$type": "color", "$value": "#6b7280" },
        "muted":     { "$type": "color", "$value": "#9ca3af" }
      },
      "accent":      { "$type": "color", "$value": "#2563eb" },
      "accentHover": { "$type": "color", "$value": "#1d4ed8" },
      "error":       { "$type": "color", "$value": "#dc2626" },
      "errorBg":     { "$type": "color", "$value": "#fef2f2" },
      "success":     { "$type": "color", "$value": "#16a34a" },
      "successBg":   { "$type": "color", "$value": "#f0fdf4" }
    },
    "spacing": {
      "xs":  { "$type": "dimension", "$value": { "value": 4,  "unit": "px" } },
      "sm":  { "$type": "dimension", "$value": { "value": 8,  "unit": "px" } },
      "md":  { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
      "lg":  { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "xl":  { "$type": "dimension", "$value": { "value": 32, "unit": "px" } }
    },
    "radius": {
      "sm":  { "$type": "dimension", "$value": { "value": 4,  "unit": "px" } },
      "md":  { "$type": "dimension", "$value": { "value": 8,  "unit": "px" } },
      "lg":  { "$type": "dimension", "$value": { "value": 12, "unit": "px" } }
    },
    "font": {
      "family": { "$type": "fontFamily", "$value": ["Inter", "ui-sans-serif", "system-ui", "sans-serif"] },
      "size": {
        "sm":   { "$type": "dimension", "$value": { "value": 13, "unit": "px" } },
        "base": { "$type": "dimension", "$value": { "value": 14, "unit": "px" } },
        "lg":   { "$type": "dimension", "$value": { "value": 18, "unit": "px" } },
        "xl":   { "$type": "dimension", "$value": { "value": 24, "unit": "px" } }
      },
      "weight": {
        "regular": { "$type": "number", "$value": 400 },
        "medium":  { "$type": "number", "$value": 500 },
        "bold":    { "$type": "number", "$value": 700 }
      }
    }
  },

  "$animations": {
    "fade-in": {
      "$description": "Fade in on mount",
      "duration": { "value": 200, "unit": "ms" },
      "easing": "ease-out",
      "keyframes": {
        "0":   { "opacity": 0 },
        "100": { "opacity": 1 }
      }
    },
    "slide-up": {
      "$description": "Toast slides up from bottom",
      "duration": { "value": 300, "unit": "ms" },
      "easing": "ease-out",
      "keyframes": {
        "0":   { "opacity": 0, "translateY": { "value": 16, "unit": "px" } },
        "100": { "opacity": 1, "translateY": { "value": 0,  "unit": "px" } }
      }
    },
    "skeleton-pulse": {
      "$description": "Skeleton loading pulse",
      "duration": { "value": 1500, "unit": "ms" },
      "easing": "ease-in-out",
      "repeat": "infinite",
      "keyframes": {
        "0":   { "opacity": 0.4 },
        "50":  { "opacity": 1 },
        "100": { "opacity": 0.4 }
      }
    }
  },

  "$elements": {
    "skeleton-row": {
      "$description": "A placeholder skeleton row for loading state",
      "type": "shape",
      "shape": "rectangle",
      "size": { "width": "fill", "height": { "value": 20, "unit": "px" } },
      "fill": "{color.surfaceAlt}",
      "cornerRadius": "{radius.sm}",
      "animation": "skeleton-pulse",
      "aria": { "hidden": true }
    },
    "field-group": {
      "$description": "Labeled form field",
      "type": "group",
      "params": ["name", "label"],
      "layout": "stack-v",
      "gap": "{spacing.xs}",
      "children": [
        {
          "type": "text",
          "binding": { "content": ["param", "label"] },
          "style": { "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.medium}", "color": "{color.text.secondary}" }
        },
        {
          "type": "input",
          "binding": { "name": ["param", "name"] },
          "onChange": [
            { "kind": "emit", "event": "FIELD_CHANGED" }
          ],
          "style": {
            "height": { "value": 36, "unit": "px" },
            "padding": { "horizontal": "{spacing.sm}" },
            "fontSize": "{font.size.base}",
            "color": "{color.text.primary}",
            "background": "{color.bg}",
            "borderWidth": { "value": 1, "unit": "px" },
            "borderColor": "{color.stroke}",
            "cornerRadius": "{radius.sm}"
          },
          "testId": "field-input"
        }
      ]
    },
    "toast": {
      "$description": "Feedback toast notification",
      "type": "group",
      "layout": "stack-h",
      "align": "center",
      "gap": "{spacing.sm}",
      "padding": { "horizontal": "{spacing.md}", "vertical": "{spacing.sm}" },
      "cornerRadius": "{radius.md}",
      "animation": "slide-up",
      "testId": "toast",
      "aria": { "role": "status", "live": "polite" }
    }
  },

  "$context": {
    "resourceId":   { "type": "string",  "required": true,    "$description": "URL or route param identifying the resource" },
    "loading":      { "type": "boolean", "default": true,     "$description": "Whether the initial load is in progress" },
    "resource":     { "type": "object",  "default": null,     "$description": "The loaded resource object" },
    "snapshot":     { "type": "object",  "default": null,     "$description": "Pre-save snapshot for rollback on failure" },
    "draftName":    { "type": "string",  "default": "",       "$description": "Editable name field value" },
    "draftEmail":   { "type": "string",  "default": "",       "$description": "Editable email field value" },
    "saving":       { "type": "boolean", "default": false,    "$description": "Whether a save request is in flight" },
    "saveError":    { "type": "string",  "default": null,     "$description": "Error message from a failed save" },
    "loadError":    { "type": "string",  "default": null,     "$description": "Error message from a failed load" },
    "toastMessage": { "type": "string",  "default": null,     "$description": "Current toast text" },
    "toastVariant": { "type": "string",  "default": "success", "$description": "Toast style: success or error" }
  },

  "$events": {
    "LOAD_OK": {
      "source": "network",
      "payload": {
        "resource": { "type": "object" }
      }
    },
    "LOAD_EMPTY": {
      "source": "network",
      "payload": {}
    },
    "LOAD_ERROR": {
      "source": "network",
      "payload": {
        "message": { "type": "string" }
      }
    },
    "RETRY": {
      "source": "user",
      "payload": {}
    },
    "EDIT": {
      "source": "user",
      "payload": {}
    },
    "CANCEL_EDIT": {
      "source": "user",
      "payload": {}
    },
    "FIELD_CHANGED": {
      "source": "user",
      "payload": {
        "name":  { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "SAVE": {
      "source": "user",
      "payload": {}
    },
    "SAVE_OK": {
      "source": "network",
      "payload": {
        "resource": { "type": "object" }
      }
    },
    "SAVE_ERROR": {
      "source": "network",
      "payload": {
        "message": { "type": "string" }
      }
    },
    "TOAST_DISMISS": {
      "source": "timer",
      "payload": {}
    },
    "CREATE": {
      "source": "user",
      "payload": {}
    }
  },

  "$machine": {
    "id": "resourcePage",
    "initial": "loading",

    "$visual": {
      "$description": "Full-width page container with top nav breadcrumb area",
      "container": {
        "layout": "stack-v",
        "size": { "width": "fill", "minHeight": "fill" },
        "padding": { "horizontal": "{spacing.xl}", "vertical": "{spacing.lg}" },
        "background": "{color.bg}"
      }
    },

    "states": {
      "loading": {
        "entry": [
          { "kind": "http", "request": "loadResource" },
          { "kind": "log", "level": "info", "message": "resource_load_start" }
        ],
        "$visual": {
          "$description": "Skeleton placeholder rows while data loads",
          "animation": "fade-in",
          "slots": {
            "content": [
              {
                "type": "group", "name": "skeleton-container",
                "layout": "stack-v", "gap": "{spacing.md}",
                "testId": "loading-skeleton",
                "aria": { "role": "status", "label": "Loading resource", "busy": true },
                "children": [
                  { "$ref": "skeleton-row" },
                  { "$ref": "skeleton-row" },
                  { "$ref": "skeleton-row" },
                  { "$ref": "skeleton-row" }
                ]
              }
            ]
          }
        },
        "on": {
          "LOAD_OK": {
            "target": "ready",
            "actions": [
              { "kind": "assign", "path": "context.resource",  "value": ["var", "event.resource"] },
              { "kind": "assign", "path": "context.loading",   "value": false },
              { "kind": "log", "level": "info", "message": "resource_load_ok" }
            ]
          },
          "LOAD_EMPTY": {
            "target": "empty",
            "actions": [
              { "kind": "assign", "path": "context.loading", "value": false },
              { "kind": "log", "level": "info", "message": "resource_load_empty" }
            ]
          },
          "LOAD_ERROR": {
            "target": "error",
            "actions": [
              { "kind": "assign", "path": "context.loadError", "value": ["var", "event.message"] },
              { "kind": "assign", "path": "context.loading",   "value": false },
              { "kind": "log", "level": "error", "message": "resource_load_error" }
            ]
          }
        }
      },

      "ready": {
        "initial": "viewing",
        "$visual": {
          "$description": "Resource loaded — shows data with edit button",
          "animation": "fade-in"
        },
        "states": {
          "viewing": {
            "$visual": {
              "$description": "Read-only display of resource fields with an Edit button",
              "slots": {
                "content": [
                  {
                    "type": "group", "name": "resource-display",
                    "layout": "stack-v", "gap": "{spacing.lg}",
                    "testId": "resource-display",
                    "children": [
                      {
                        "type": "text", "name": "resource-name",
                        "binding": { "content": ["var", "context.draftName"] },
                        "style": { "fontSize": "{font.size.xl}", "fontWeight": "{font.weight.bold}", "color": "{color.text.primary}" },
                        "testId": "resource-name",
                        "aria": { "role": "heading", "level": 1 }
                      },
                      {
                        "type": "text", "name": "resource-email",
                        "binding": { "content": ["var", "context.draftEmail"] },
                        "style": { "fontSize": "{font.size.base}", "color": "{color.text.secondary}" },
                        "testId": "resource-email"
                      },
                      {
                        "type": "button", "name": "edit-button",
                        "content": "Edit",
                        "onPress": [
                          { "kind": "emit", "event": "EDIT" }
                        ],
                        "style": {
                          "background": "{color.accent}",
                          "color": "{color.bg}",
                          "cornerRadius": "{radius.sm}",
                          "padding": { "horizontal": "{spacing.md}", "vertical": "{spacing.sm}" }
                        },
                        "testId": "resource-edit-btn",
                        "aria": { "label": "Edit resource" }
                      }
                    ]
                  }
                ]
              }
            },
            "on": {
              "EDIT": {
                "target": "editing",
                "actions": [
                  { "kind": "assign", "path": "context.snapshot", "value": ["var", "context.resource"] },
                  { "kind": "log", "level": "info", "message": "resource_edit_start" }
                ]
              }
            }
          },

          "editing": {
            "$visual": {
              "$description": "Editable form with name and email fields, Save and Cancel buttons",
              "slots": {
                "content": [
                  {
                    "type": "group", "name": "edit-form",
                    "layout": "stack-v", "gap": "{spacing.md}",
                    "testId": "resource-edit-form",
                    "aria": { "role": "form", "label": "Edit resource" },
                    "children": [
                      {
                        "$ref": "field-group", "name": "draftName", "label": "Name",
                        "testId": "edit-name",
                        "aria": { "label": "Resource name" }
                      },
                      {
                        "$ref": "field-group", "name": "draftEmail", "label": "Email",
                        "testId": "edit-email",
                        "aria": { "label": "Resource email" }
                      },
                      {
                        "type": "group", "name": "form-actions",
                        "layout": "stack-h", "gap": "{spacing.sm}",
                        "children": [
                          {
                            "type": "button", "name": "save-button",
                            "content": "Save",
                            "onPress": [
                              { "kind": "emit", "event": "SAVE" }
                            ],
                            "enabledWhen": ["==", ["var", "context.saving"], false],
                            "style": {
                              "background": "{color.accent}",
                              "color": "{color.bg}",
                              "cornerRadius": "{radius.sm}",
                              "padding": { "horizontal": "{spacing.md}", "vertical": "{spacing.sm}" }
                            },
                            "testId": "resource-save-btn",
                            "aria": { "label": "Save changes" }
                          },
                          {
                            "type": "button", "name": "cancel-button",
                            "content": "Cancel",
                            "onPress": [
                              { "kind": "emit", "event": "CANCEL_EDIT" }
                            ],
                            "enabledWhen": ["==", ["var", "context.saving"], false],
                            "style": {
                              "background": "transparent",
                              "color": "{color.text.secondary}",
                              "borderWidth": { "value": 1, "unit": "px" },
                              "borderColor": "{color.stroke}",
                              "cornerRadius": "{radius.sm}",
                              "padding": { "horizontal": "{spacing.md}", "vertical": "{spacing.sm}" }
                            },
                            "testId": "resource-cancel-btn",
                            "aria": { "label": "Cancel editing" }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            "on": {
              "FIELD_CHANGED": {
                "target": "editing",
                "actions": [
                  { "kind": "log", "level": "info", "message": "resource_field_changed" }
                ]
              },
              "SAVE": {
                "target": "saving",
                "actions": [
                  { "kind": "assign", "path": "context.saving",   "value": true },
                  { "kind": "assign", "path": "context.saveError", "value": null },
                  { "kind": "log", "level": "info", "message": "resource_save_start" }
                ]
              },
              "CANCEL_EDIT": {
                "target": "viewing",
                "actions": [
                  { "kind": "assign", "path": "context.resource",  "value": ["var", "context.snapshot"] },
                  { "kind": "assign", "path": "context.snapshot",  "value": null },
                  { "kind": "log", "level": "info", "message": "resource_edit_cancel" }
                ]
              }
            }
          },

          "saving": {
            "entry": [
              { "kind": "http", "request": "saveResource" }
            ],
            "$visual": {
              "$description": "Save button shows spinner; form fields disabled; optimistic UI shows updated values"
            },
            "on": {
              "SAVE_OK": {
                "target": "viewing",
                "actions": [
                  { "kind": "assign", "path": "context.resource",     "value": ["var", "event.resource"] },
                  { "kind": "assign", "path": "context.saving",       "value": false },
                  { "kind": "assign", "path": "context.snapshot",     "value": null },
                  { "kind": "assign", "path": "context.toastMessage", "value": "Changes saved successfully" },
                  { "kind": "assign", "path": "context.toastVariant", "value": "success" },
                  { "kind": "log", "level": "info", "message": "resource_save_ok" }
                ]
              },
              "SAVE_ERROR": {
                "target": "saveError",
                "actions": [
                  { "kind": "assign", "path": "context.resource",  "value": ["var", "context.snapshot"] },
                  { "kind": "assign", "path": "context.saving",    "value": false },
                  { "kind": "assign", "path": "context.saveError", "value": ["var", "event.message"] },
                  { "kind": "log", "level": "error", "message": "resource_save_error" }
                ]
              }
            }
          },

          "saveError": {
            "$visual": {
              "$description": "Inline error banner above form, fields preserved with pre-save values (rollback applied), retry available",
              "slots": {
                "content": [
                  {
                    "type": "group", "name": "save-error-container",
                    "layout": "stack-v", "gap": "{spacing.md}",
                    "testId": "save-error-container",
                    "children": [
                      {
                        "type": "group", "name": "error-banner",
                        "layout": "stack-h", "align": "center", "gap": "{spacing.sm}",
                        "padding": { "horizontal": "{spacing.md}", "vertical": "{spacing.sm}" },
                        "background": "{color.errorBg}",
                        "cornerRadius": "{radius.sm}",
                        "testId": "save-error-banner",
                        "aria": { "role": "alert" },
                        "children": [
                          { "type": "icon", "icon": "AlertCircle", "size": { "value": 16, "unit": "px" }, "color": "{color.error}" },
                          {
                            "type": "text",
                            "binding": { "content": ["var", "context.saveError"] },
                            "style": { "fontSize": "{font.size.sm}", "color": "{color.error}" }
                          }
                        ]
                      },
                      {
                        "type": "button", "name": "retry-save",
                        "content": "Retry Save",
                        "onPress": [
                          { "kind": "emit", "event": "SAVE" }
                        ],
                        "style": {
                          "background": "{color.accent}",
                          "color": "{color.bg}",
                          "cornerRadius": "{radius.sm}",
                          "padding": { "horizontal": "{spacing.md}", "vertical": "{spacing.sm}" }
                        },
                        "testId": "save-retry-btn",
                        "aria": { "label": "Retry saving changes" }
                      }
                    ]
                  }
                ]
              }
            },
            "on": {
              "SAVE": {
                "target": "saving",
                "actions": [
                  { "kind": "assign", "path": "context.saving",   "value": true },
                  { "kind": "assign", "path": "context.saveError", "value": null }
                ]
              },
              "CANCEL_EDIT": {
                "target": "viewing",
                "actions": [
                  { "kind": "assign", "path": "context.saveError", "value": null },
                  { "kind": "assign", "path": "context.snapshot",  "value": null }
                ]
              }
            }
          }
        }
      },

      "empty": {
        "$visual": {
          "$description": "Zero state — illustration, explanatory text, and a create CTA",
          "animation": "fade-in",
          "slots": {
            "content": [
              {
                "type": "group", "name": "empty-state",
                "layout": "stack-v", "align": "center", "gap": "{spacing.lg}",
                "padding": { "vertical": "{spacing.xl}" },
                "testId": "empty-state",
                "aria": { "role": "status" },
                "children": [
                  { "type": "icon", "icon": "Inbox", "size": { "value": 64, "unit": "px" }, "color": "{color.text.muted}" },
                  {
                    "type": "text", "content": "No resources found",
                    "style": { "fontSize": "{font.size.lg}", "fontWeight": "{font.weight.medium}", "color": "{color.text.primary}" },
                    "testId": "empty-title"
                  },
                  {
                    "type": "text", "content": "Create your first resource to get started.",
                    "style": { "fontSize": "{font.size.base}", "color": "{color.text.secondary}" },
                    "testId": "empty-description"
                  },
                  {
                    "type": "button", "name": "create-button",
                    "content": "Create Resource",
                    "onPress": [
                      { "kind": "emit", "event": "CREATE" }
                    ],
                    "style": {
                      "background": "{color.accent}",
                      "color": "{color.bg}",
                      "cornerRadius": "{radius.sm}",
                      "padding": { "horizontal": "{spacing.lg}", "vertical": "{spacing.sm}" }
                    },
                    "testId": "empty-create-btn",
                    "aria": { "label": "Create new resource" }
                  }
                ]
              }
            ]
          }
        },
        "on": {
          "CREATE": {
            "target": "loading",
            "actions": [
              { "kind": "assign", "path": "context.loading", "value": true },
              { "kind": "log", "level": "info", "message": "resource_create_start" }
            ]
          }
        }
      },

      "error": {
        "$visual": {
          "$description": "Load error with retry button",
          "animation": "fade-in",
          "slots": {
            "content": [
              {
                "type": "group", "name": "error-state",
                "layout": "stack-v", "align": "center", "gap": "{spacing.lg}",
                "padding": { "vertical": "{spacing.xl}" },
                "testId": "error-state",
                "aria": { "role": "alert" },
                "children": [
                  { "type": "icon", "icon": "AlertTriangle", "size": { "value": 48, "unit": "px" }, "color": "{color.error}" },
                  {
                    "type": "text", "content": "Failed to load resource",
                    "style": { "fontSize": "{font.size.lg}", "fontWeight": "{font.weight.medium}", "color": "{color.text.primary}" },
                    "testId": "error-title"
                  },
                  {
                    "type": "text",
                    "binding": { "content": ["var", "context.loadError"] },
                    "style": { "fontSize": "{font.size.base}", "color": "{color.text.secondary}" },
                    "testId": "error-message"
                  },
                  {
                    "type": "button", "name": "retry-button",
                    "content": "Retry",
                    "onPress": [
                      { "kind": "emit", "event": "RETRY" }
                    ],
                    "style": {
                      "background": "{color.accent}",
                      "color": "{color.bg}",
                      "cornerRadius": "{radius.sm}",
                      "padding": { "horizontal": "{spacing.lg}", "vertical": "{spacing.sm}" }
                    },
                    "testId": "error-retry-btn",
                    "aria": { "label": "Retry loading resource" }
                  }
                ]
              }
            ]
          }
        },
        "on": {
          "RETRY": {
            "target": "loading",
            "actions": [
              { "kind": "assign", "path": "context.loading",   "value": true },
              { "kind": "assign", "path": "context.loadError", "value": null },
              { "kind": "log", "level": "info", "message": "resource_retry" }
            ]
          }
        }
      }
    }
  }
}
