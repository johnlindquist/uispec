{
  "$schema": "https://uxspec.dev/0.2/schema.json",
  "$description": "Authentication flow — multi-page with conditional routing. Demonstrates guards (via context), form inputs, error states, loading substates, and page-level layout transitions. Edge cases: OAuth redirect, email verification pending, rate limiting.",

  "$tokens": {
    "color": {
      "bg":          { "$type": "color", "$value": "#000000" },
      "surface":     { "$type": "color", "$value": "#111111" },
      "surfaceAlt":  { "$type": "color", "$value": "#1a1a1a" },
      "stroke":      { "$type": "color", "$value": "rgba(255, 255, 255, 0.12)" },
      "text": {
        "primary":   { "$type": "color", "$value": "#ffffff" },
        "secondary": { "$type": "color", "$value": "rgba(255, 255, 255, 0.6)" },
        "muted":     { "$type": "color", "$value": "rgba(255, 255, 255, 0.4)" }
      },
      "accent":      { "$type": "color", "$value": "#0070f3" },
      "accentHover": { "$type": "color", "$value": "#0060df" },
      "error":       { "$type": "color", "$value": "#ee5555" },
      "errorBg":     { "$type": "color", "$value": "rgba(238, 85, 85, 0.1)" },
      "success":     { "$type": "color", "$value": "#52c41a" },
      "github":      { "$type": "color", "$value": "#ffffff" },
      "google":      { "$type": "color", "$value": "#4285f4" }
    },
    "spacing": {
      "xs":  { "$type": "dimension", "$value": { "value": 4,  "unit": "px" } },
      "sm":  { "$type": "dimension", "$value": { "value": 8,  "unit": "px" } },
      "md":  { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
      "lg":  { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "xl":  { "$type": "dimension", "$value": { "value": 32, "unit": "px" } },
      "xxl": { "$type": "dimension", "$value": { "value": 48, "unit": "px" } }
    },
    "radius": {
      "sm":  { "$type": "dimension", "$value": { "value": 6,  "unit": "px" } },
      "md":  { "$type": "dimension", "$value": { "value": 8,  "unit": "px" } },
      "lg":  { "$type": "dimension", "$value": { "value": 12, "unit": "px" } },
      "full": { "$type": "dimension", "$value": { "value": 9999, "unit": "px" } }
    },
    "font": {
      "family": { "$type": "fontFamily", "$value": ["Inter", "ui-sans-serif", "system-ui", "sans-serif"] },
      "size": {
        "sm":   { "$type": "dimension", "$value": { "value": 13, "unit": "px" } },
        "base": { "$type": "dimension", "$value": { "value": 14, "unit": "px" } },
        "lg":   { "$type": "dimension", "$value": { "value": 18, "unit": "px" } },
        "xl":   { "$type": "dimension", "$value": { "value": 24, "unit": "px" } }
      },
      "weight": {
        "regular": { "$type": "number", "$value": 400 },
        "medium":  { "$type": "number", "$value": 500 },
        "bold":    { "$type": "number", "$value": 700 }
      }
    },
    "timing": {
      "fast":   { "$type": "duration", "$value": { "value": 150, "unit": "ms" } },
      "normal": { "$type": "duration", "$value": { "value": 250, "unit": "ms" } }
    }
  },

  "$animations": {
    "page-enter": {
      "$description": "Page slides up and fades in",
      "duration": "{timing.normal}",
      "easing": "ease-out",
      "keyframes": {
        "0":   { "opacity": 0, "translateY": { "value": 8, "unit": "px" } },
        "100": { "opacity": 1, "translateY": { "value": 0, "unit": "px" } }
      }
    },
    "shake": {
      "$description": "Error shake on form",
      "duration": { "value": 400, "unit": "ms" },
      "easing": "ease-out",
      "keyframes": {
        "0":   { "translateX": { "value": 0,   "unit": "px" } },
        "20":  { "translateX": { "value": -8,  "unit": "px" } },
        "40":  { "translateX": { "value": 8,   "unit": "px" } },
        "60":  { "translateX": { "value": -4,  "unit": "px" } },
        "80":  { "translateX": { "value": 4,   "unit": "px" } },
        "100": { "translateX": { "value": 0,   "unit": "px" } }
      }
    },
    "spinner": {
      "$description": "Rotating spinner for loading states",
      "duration": { "value": 800, "unit": "ms" },
      "easing": "linear",
      "repeat": "infinite",
      "keyframes": {
        "0":   { "rotate": 0 },
        "100": { "rotate": 360 }
      }
    }
  },

  "$elements": {
    "text-input": {
      "$description": "Styled text input with label, placeholder, and error state. Uses group container to wrap label + input.",
      "type": "group",
      "params": ["name", "label", "placeholder", "inputType"],
      "layout": "stack-v",
      "gap": "{spacing.xs}",
      "children": [
        {
          "type": "text",
          "binding": { "content": ["param", "label"] },
          "style": { "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.medium}", "color": "{color.text.secondary}" }
        },
        {
          "type": "input",
          "binding": {
            "name": ["param", "name"],
            "inputType": ["param", "inputType"],
            "placeholder": ["param", "placeholder"]
          },
          "onChange": [
            { "kind": "emit", "event": "FIELD_CHANGED" }
          ],
          "style": {
            "height": { "value": 40, "unit": "px" },
            "padding": { "horizontal": "{spacing.md}" },
            "fontSize": "{font.size.base}",
            "color": "{color.text.primary}",
            "background": "{color.surfaceAlt}",
            "borderWidth": { "value": 1, "unit": "px" },
            "borderColor": "{color.stroke}",
            "cornerRadius": "{radius.sm}"
          },
          "interactions": {
            "focus": { "borderColor": "{color.accent}", "outlineWidth": { "value": 2, "unit": "px" }, "outlineColor": "rgba(0, 112, 243, 0.3)" }
          },
          "testId": "input-field"
        }
      ]
    },
    "primary-button": {
      "$description": "Full-width primary action button",
      "type": "button",
      "params": ["label"],
      "size": { "width": "fill", "height": { "value": 40, "unit": "px" } },
      "cornerRadius": "{radius.sm}",
      "style": {
        "background": "{color.accent}",
        "fontSize": "{font.size.base}",
        "fontWeight": "{font.weight.medium}",
        "color": "{color.text.primary}"
      },
      "interactions": {
        "hover": { "background": "{color.accentHover}" },
        "disabled": { "opacity": 0.5 }
      }
    },
    "oauth-button": {
      "$description": "OAuth provider button with icon",
      "type": "button",
      "params": ["provider", "icon", "label"],
      "size": { "width": "fill", "height": { "value": 40, "unit": "px" } },
      "cornerRadius": "{radius.sm}",
      "layout": "stack-h",
      "align": "center",
      "justify": "center",
      "gap": "{spacing.sm}",
      "style": {
        "background": "transparent",
        "borderWidth": { "value": 1, "unit": "px" },
        "borderColor": "{color.stroke}",
        "fontSize": "{font.size.base}",
        "fontWeight": "{font.weight.medium}",
        "color": "{color.text.primary}"
      },
      "interactions": {
        "hover": { "background": "{color.surfaceAlt}" }
      }
    },
    "error-message": {
      "$description": "Inline error message below a field or form",
      "type": "text",
      "params": ["message"],
      "style": {
        "fontSize": "{font.size.sm}",
        "color": "{color.error}"
      },
      "aria": { "role": "alert", "live": "assertive" }
    }
  },

  "$context": {
    "email":              { "type": "string",  "default": "",    "$description": "Current email field value" },
    "password":           { "type": "string",  "default": "",    "$description": "Current password field value" },
    "name":               { "type": "string",  "default": "",    "$description": "User display name (sign-up only)" },
    "confirmPassword":    { "type": "string",  "default": "",    "$description": "Confirm password field (sign-up only)" },
    "submitting":         { "type": "boolean", "default": false, "$description": "Whether a submit request is in flight" },
    "errorMessage":       { "type": "string",  "default": null,  "$description": "Most recent error message from the server" },
    "retryAfterSeconds":  { "type": "number",  "default": 0,     "$description": "Countdown seconds when rate-limited" },
    "oauthProvider":      { "type": "string",  "default": null,  "$description": "Which OAuth provider is being used" },
    "userId":             { "type": "string",  "default": null,  "$description": "Authenticated user ID after success" }
  },

  "$events": {
    "FIELD_CHANGED": {
      "source": "user",
      "payload": {
        "name":  { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "SUBMIT": {
      "source": "user",
      "payload": {}
    },
    "SUBMIT_EMAIL": {
      "source": "user",
      "payload": {}
    },
    "SUCCESS": {
      "source": "network",
      "payload": {
        "userId": { "type": "string" }
      }
    },
    "INVALID_CREDENTIALS": {
      "source": "network",
      "payload": {
        "message": { "type": "string" }
      }
    },
    "RATE_LIMITED": {
      "source": "network",
      "payload": {
        "retryAfterSeconds": { "type": "number" }
      }
    },
    "NEEDS_VERIFICATION": {
      "source": "network",
      "payload": {}
    },
    "COOLDOWN_EXPIRED": {
      "source": "timer",
      "payload": {}
    },
    "EDIT": {
      "source": "user",
      "payload": {}
    },
    "OAUTH_GITHUB": {
      "source": "user",
      "payload": {}
    },
    "OAUTH_GOOGLE": {
      "source": "user",
      "payload": {}
    },
    "OAUTH_SUCCESS": {
      "source": "network",
      "payload": {
        "userId": { "type": "string" }
      }
    },
    "OAUTH_ERROR": {
      "source": "network",
      "payload": {
        "message": { "type": "string" }
      }
    },
    "OAUTH_CANCEL": {
      "source": "user",
      "payload": {}
    },
    "GO_TO_SIGNUP": {
      "source": "user",
      "payload": {}
    },
    "GO_TO_SIGNIN": {
      "source": "user",
      "payload": {}
    },
    "VALIDATE_FIELD": {
      "source": "user",
      "payload": {
        "name": { "type": "string" }
      }
    },
    "VALID": {
      "source": "system",
      "payload": {}
    },
    "EMAIL_TAKEN": {
      "source": "network",
      "payload": {
        "message": { "type": "string" }
      }
    },
    "WEAK_PASSWORD": {
      "source": "network",
      "payload": {
        "message": { "type": "string" }
      }
    },
    "VERIFIED": {
      "source": "network",
      "payload": {}
    },
    "RESEND": {
      "source": "user",
      "payload": {}
    },
    "RESENT": {
      "source": "network",
      "payload": {}
    },
    "RESEND_FAILED": {
      "source": "network",
      "payload": {
        "message": { "type": "string" }
      }
    },
    "BACK": {
      "source": "user",
      "payload": {}
    }
  },

  "$machine": {
    "id": "authFlow",
    "initial": "signIn",

    "$visual": {
      "$description": "Full-page centered card on dark background",
      "container": {
        "layout": "layer",
        "align": "center",
        "justify": "center",
        "size": { "width": "fill", "height": "fill" },
        "background": "{color.bg}"
      }
    },

    "states": {
      "signIn": {
        "on": {
          "SUBMIT_EMAIL": {
            "target": "signIn.loading",
            "actions": [
              { "kind": "assign", "path": "context.submitting", "value": true }
            ]
          },
          "OAUTH_GITHUB": {
            "target": "oauthRedirect",
            "actions": [
              { "kind": "assign", "path": "context.oauthProvider", "value": "github" }
            ]
          },
          "OAUTH_GOOGLE": {
            "target": "oauthRedirect",
            "actions": [
              { "kind": "assign", "path": "context.oauthProvider", "value": "google" }
            ]
          },
          "GO_TO_SIGNUP": "signUp"
        },
        "initial": "idle",
        "$visual": {
          "$description": "Sign-in page. Centered card with email input, password input, submit button, OAuth buttons, and sign-up link.",
          "animation": "page-enter",
          "slots": {
            "content": [
              {
                "type": "group", "name": "auth-card",
                "layout": "stack-v", "align": "stretch",
                "gap": "{spacing.lg}",
                "size": { "width": { "value": 360, "unit": "px" } },
                "padding": { "value": "{spacing.xl}" },
                "background": "{color.surface}",
                "cornerRadius": "{radius.lg}",
                "borderWidth": { "value": 1, "unit": "px" },
                "borderColor": "{color.stroke}",
                "testId": "auth-card",
                "children": [
                  {
                    "type": "text",
                    "content": "auth.signIn.title",
                    "style": { "fontSize": "{font.size.xl}", "fontWeight": "{font.weight.bold}", "color": "{color.text.primary}" },
                    "testId": "auth-title",
                    "aria": { "role": "heading", "level": 1 }
                  },
                  {
                    "$ref": "text-input", "name": "email", "label": "auth.email", "placeholder": "auth.emailPlaceholder", "inputType": "email",
                    "testId": "auth-email",
                    "aria": { "label": "Email address", "required": true }
                  },
                  {
                    "$ref": "text-input", "name": "password", "label": "auth.password", "placeholder": "auth.passwordPlaceholder", "inputType": "password",
                    "testId": "auth-password",
                    "aria": { "label": "Password", "required": true }
                  },
                  {
                    "$ref": "primary-button", "label": "auth.signIn.submit",
                    "onPress": [
                      { "kind": "emit", "event": "SUBMIT_EMAIL" }
                    ],
                    "enabledWhen": ["==", ["var", "context.submitting"], false],
                    "testId": "auth-submit",
                    "aria": { "label": "Sign in" }
                  },
                  { "type": "group", "name": "divider", "layout": "stack-h", "align": "center", "gap": "{spacing.md}", "children": [
                    { "type": "shape", "shape": "rectangle", "size": { "width": "fill", "height": { "value": 1, "unit": "px" } }, "fill": "{color.stroke}" },
                    { "type": "text", "content": "auth.or", "style": { "fontSize": "{font.size.sm}", "color": "{color.text.muted}" } },
                    { "type": "shape", "shape": "rectangle", "size": { "width": "fill", "height": { "value": 1, "unit": "px" } }, "fill": "{color.stroke}" }
                  ]},
                  {
                    "$ref": "oauth-button", "provider": "github", "icon": "Github", "label": "auth.continueWithGithub",
                    "onPress": [
                      { "kind": "emit", "event": "OAUTH_GITHUB" }
                    ],
                    "testId": "auth-oauth-github"
                  },
                  {
                    "$ref": "oauth-button", "provider": "google", "icon": "Google", "label": "auth.continueWithGoogle",
                    "onPress": [
                      { "kind": "emit", "event": "OAUTH_GOOGLE" }
                    ],
                    "testId": "auth-oauth-google"
                  },
                  { "type": "group", "name": "signup-prompt", "layout": "stack-h", "align": "center", "justify": "center", "gap": "{spacing.xs}",
                    "children": [
                      { "type": "text", "content": "auth.noAccount", "style": { "fontSize": "{font.size.sm}", "color": "{color.text.muted}" } },
                      {
                        "type": "text", "content": "auth.signUpLink",
                        "style": { "fontSize": "{font.size.sm}", "color": "{color.accent}" },
                        "onPress": [
                          { "kind": "emit", "event": "GO_TO_SIGNUP" }
                        ],
                        "testId": "auth-signup-link"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
        "states": {
          "idle": {
            "entry": [
              { "kind": "assign", "path": "context.submitting",   "value": false },
              { "kind": "assign", "path": "context.errorMessage", "value": null }
            ],
            "$visual": { "$description": "Form ready for input" },
            "on": {
              "SUBMIT": {
                "target": "loading",
                "actions": [
                  { "kind": "assign", "path": "context.submitting", "value": true }
                ]
              }
            }
          },
          "loading": {
            "entry": [
              { "kind": "http", "request": "signIn" },
              { "kind": "log", "level": "info", "message": "auth_signin_submit" }
            ],
            "$visual": {
              "$description": "Submit button shows spinner, inputs disabled",
              "slots": {
                "content": [{ "$description": "Same card but submit button shows spinner animation and all inputs are disabled" }]
              }
            },
            "on": {
              "SUCCESS":              "success",
              "INVALID_CREDENTIALS":  {
                "target": "error",
                "actions": [
                  { "kind": "assign", "path": "context.errorMessage",  "value": ["var", "event.message"] },
                  { "kind": "assign", "path": "context.submitting",    "value": false }
                ]
              },
              "RATE_LIMITED": {
                "target": "rateLimited",
                "actions": [
                  { "kind": "assign", "path": "context.retryAfterSeconds", "value": ["var", "event.retryAfterSeconds"] },
                  { "kind": "assign", "path": "context.submitting",        "value": false }
                ]
              },
              "NEEDS_VERIFICATION": "needsVerification"
            }
          },
          "error": {
            "$visual": {
              "$description": "Card shakes, error message appears below password field",
              "animation": "shake"
            },
            "on": {
              "SUBMIT": {
                "target": "loading",
                "actions": [
                  { "kind": "assign", "path": "context.submitting", "value": true }
                ]
              },
              "EDIT": "idle"
            }
          },
          "rateLimited": {
            "entry": [
              { "kind": "timer.start", "id": "cooldown", "ms": 1000, "event": "COOLDOWN_EXPIRED" },
              { "kind": "log", "level": "info", "message": "auth_rate_limited" }
            ],
            "$visual": {
              "$description": "Error message: 'Too many attempts. Try again in {retryAfterSeconds}s.' Submit button disabled with countdown."
            },
            "on": { "COOLDOWN_EXPIRED": "idle" }
          },
          "needsVerification": {
            "always": [
              { "target": "emailVerification", "guard": true, "actions": [] }
            ],
            "$visual": { "$description": "Transitions to emailVerification state" }
          },
          "success": {
            "entry": [
              { "kind": "assign", "path": "context.submitting", "value": false },
              { "kind": "log", "level": "info", "message": "auth_signin_success" }
            ],
            "always": [
              { "target": "authenticated", "guard": true, "actions": [] }
            ],
            "$visual": { "$description": "Brief green checkmark, then redirect" }
          }
        }
      },

      "signUp": {
        "on": { "GO_TO_SIGNIN": "signIn" },
        "initial": "idle",
        "$visual": {
          "$description": "Sign-up page. Same card layout as sign-in but with name field and confirm password. Has link back to sign-in.",
          "animation": "page-enter",
          "slots": {
            "content": [
              {
                "type": "group", "name": "auth-card",
                "layout": "stack-v", "align": "stretch",
                "gap": "{spacing.lg}",
                "size": { "width": { "value": 360, "unit": "px" } },
                "padding": { "value": "{spacing.xl}" },
                "background": "{color.surface}",
                "cornerRadius": "{radius.lg}",
                "testId": "signup-card",
                "children": [
                  {
                    "type": "text", "content": "auth.signUp.title",
                    "style": { "fontSize": "{font.size.xl}", "fontWeight": "{font.weight.bold}", "color": "{color.text.primary}" },
                    "testId": "signup-title",
                    "aria": { "role": "heading", "level": 1 }
                  },
                  {
                    "$ref": "text-input", "name": "name", "label": "auth.name", "placeholder": "auth.namePlaceholder", "inputType": "text",
                    "testId": "signup-name"
                  },
                  {
                    "$ref": "text-input", "name": "email", "label": "auth.email", "placeholder": "auth.emailPlaceholder", "inputType": "email",
                    "testId": "signup-email"
                  },
                  {
                    "$ref": "text-input", "name": "password", "label": "auth.password", "placeholder": "auth.passwordPlaceholder", "inputType": "password",
                    "testId": "signup-password"
                  },
                  {
                    "$ref": "text-input", "name": "confirmPassword", "label": "auth.confirmPassword", "placeholder": "auth.confirmPasswordPlaceholder", "inputType": "password",
                    "testId": "signup-confirm-password"
                  },
                  {
                    "$ref": "primary-button", "label": "auth.signUp.submit",
                    "onPress": [
                      { "kind": "emit", "event": "SUBMIT" }
                    ],
                    "enabledWhen": ["==", ["var", "context.submitting"], false],
                    "testId": "signup-submit",
                    "aria": { "label": "Create account" }
                  }
                ]
              }
            ]
          }
        },
        "states": {
          "idle": {
            "entry": [
              { "kind": "assign", "path": "context.submitting",   "value": false },
              { "kind": "assign", "path": "context.errorMessage", "value": null }
            ],
            "$visual": { "$description": "Form ready for input" },
            "on": { "SUBMIT": "loading", "VALIDATE_FIELD": "validating" }
          },
          "validating": {
            "$visual": { "$description": "Real-time field validation — password strength indicator, email format check. Per-field error messages appear below invalid fields." },
            "on": { "VALID": "idle", "SUBMIT": "loading" }
          },
          "loading": {
            "entry": [
              { "kind": "assign", "path": "context.submitting", "value": true },
              { "kind": "http", "request": "signUp" },
              { "kind": "log", "level": "info", "message": "auth_signup_submit" }
            ],
            "$visual": { "$description": "Spinner on submit, all fields disabled" },
            "on": {
              "SUCCESS": "success",
              "EMAIL_TAKEN": {
                "target": "error",
                "actions": [
                  { "kind": "assign", "path": "context.errorMessage",  "value": ["var", "event.message"] },
                  { "kind": "assign", "path": "context.submitting",    "value": false }
                ]
              },
              "WEAK_PASSWORD": {
                "target": "error",
                "actions": [
                  { "kind": "assign", "path": "context.errorMessage",  "value": ["var", "event.message"] },
                  { "kind": "assign", "path": "context.submitting",    "value": false }
                ]
              }
            }
          },
          "error": {
            "$visual": { "$description": "Shake + field-level errors. email: 'Already registered', password: 'Must be 8+ characters'", "animation": "shake" },
            "on": { "EDIT": "idle", "SUBMIT": "loading" }
          },
          "success": {
            "entry": [
              { "kind": "log", "level": "info", "message": "auth_signup_success" }
            ],
            "always": [
              { "target": "emailVerification", "guard": true, "actions": [] }
            ],
            "$visual": { "$description": "Redirect to email verification" }
          }
        }
      },

      "emailVerification": {
        "on": {
          "VERIFIED": "authenticated",
          "RESEND": "emailVerification.resending",
          "BACK": "signIn"
        },
        "initial": "waiting",
        "$visual": {
          "$description": "Email verification pending. Shows envelope icon, 'Check your email' heading, description with the email address, and a resend button.",
          "animation": "page-enter",
          "slots": {
            "content": [
              {
                "type": "group", "name": "verification-card",
                "layout": "stack-v", "align": "center",
                "gap": "{spacing.lg}",
                "size": { "width": { "value": 360, "unit": "px" } },
                "padding": { "value": "{spacing.xl}" },
                "background": "{color.surface}",
                "cornerRadius": "{radius.lg}",
                "testId": "verification-card",
                "children": [
                  { "type": "icon", "icon": "Mail", "size": { "value": 48, "unit": "px" }, "color": "{color.accent}", "testId": "verification-icon" },
                  {
                    "type": "text", "content": "auth.verification.title",
                    "style": { "fontSize": "{font.size.lg}", "fontWeight": "{font.weight.bold}", "color": "{color.text.primary}", "textAlign": "center" },
                    "aria": { "role": "heading", "level": 1 }
                  },
                  {
                    "type": "text", "content": "auth.verification.description",
                    "style": { "fontSize": "{font.size.base}", "color": "{color.text.secondary}", "textAlign": "center" },
                    "binding": { "content": ["var", "context.email"] }
                  },
                  {
                    "$ref": "primary-button", "label": "auth.verification.resend",
                    "onPress": [
                      { "kind": "emit", "event": "RESEND" }
                    ],
                    "testId": "verification-resend",
                    "aria": { "label": "Resend verification email" }
                  },
                  {
                    "type": "text", "content": "auth.verification.backToSignIn",
                    "style": { "fontSize": "{font.size.sm}", "color": "{color.accent}", "textAlign": "center" },
                    "onPress": [
                      { "kind": "emit", "event": "BACK" }
                    ],
                    "testId": "verification-back"
                  }
                ]
              }
            ]
          }
        },
        "states": {
          "waiting": {
            "entry": [
              { "kind": "log", "level": "info", "message": "auth_verification_waiting" }
            ],
            "$visual": { "$description": "Waiting for user to click email link" },
            "on": { "RESEND": "resending" }
          },
          "resending": {
            "entry": [
              { "kind": "http", "request": "resendVerification" },
              { "kind": "log", "level": "info", "message": "auth_verification_resend" }
            ],
            "$visual": { "$description": "Resend button shows spinner" },
            "on": { "RESENT": "resent", "RESEND_FAILED": "resendError" }
          },
          "resent": {
            "$visual": { "$description": "Green checkmark replaces resend button, 'Email sent!' confirmation text" },
            "autoDismiss": { "value": 3000, "unit": "ms" }
          },
          "resendError": {
            "$visual": { "$description": "Red error text: 'Failed to resend. Try again.'" },
            "on": { "RESEND": "resending" }
          }
        }
      },

      "oauthRedirect": {
        "entry": [
          { "kind": "http", "request": "oauthRedirect" },
          { "kind": "log", "level": "info", "message": "auth_oauth_redirect" }
        ],
        "$visual": {
          "$description": "Full-page loading state with provider logo and 'Redirecting to {provider}...' text. Spinner animation.",
          "slots": {
            "content": [
              {
                "type": "group", "layout": "stack-v", "align": "center", "gap": "{spacing.lg}",
                "testId": "oauth-redirect",
                "children": [
                  { "type": "icon", "icon": "Loader2", "size": { "value": 32, "unit": "px" }, "color": "{color.text.secondary}", "animation": "spinner" },
                  {
                    "type": "text",
                    "binding": { "content": ["var", "context.oauthProvider"] },
                    "style": { "fontSize": "{font.size.base}", "color": "{color.text.secondary}" },
                    "aria": { "role": "status", "live": "polite" }
                  }
                ]
              }
            ]
          }
        },
        "on": {
          "OAUTH_SUCCESS": {
            "target": "authenticated",
            "actions": [
              { "kind": "assign", "path": "context.userId", "value": ["var", "event.userId"] },
              { "kind": "log", "level": "info", "message": "auth_oauth_success" }
            ]
          },
          "OAUTH_ERROR": {
            "target": "signIn.error",
            "actions": [
              { "kind": "assign", "path": "context.errorMessage", "value": ["var", "event.message"] }
            ]
          },
          "OAUTH_CANCEL": "signIn"
        }
      },

      "authenticated": {
        "entry": [
          { "kind": "log", "level": "info", "message": "auth_authenticated" },
          { "kind": "navigate", "to": "/dashboard" }
        ],
        "$visual": { "$description": "Terminal state — app redirects to main content" }
      }
    }
  }
}
