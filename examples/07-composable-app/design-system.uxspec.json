{
  "$schema": "https://raw.githubusercontent.com/johnlindquist/uxspec/main/schema/uxspec.schema.json",
  "$description": "Shared design system — tokens and reusable UI elements used across all modules.",

  "$tokens": {
    "color": {
      "neutral": {
        "50":  { "$type": "color", "$value": "#fafafa" },
        "100": { "$type": "color", "$value": "#f5f5f5" },
        "700": { "$type": "color", "$value": "#404040" },
        "900": { "$type": "color", "$value": "#171717" }
      },
      "brand": {
        "500": { "$type": "color", "$value": "#6366f1" },
        "600": { "$type": "color", "$value": "#4f46e5" }
      },
      "danger": {
        "500": { "$type": "color", "$value": "#ef4444" }
      },
      "success": {
        "500": { "$type": "color", "$value": "#22c55e" }
      }
    },
    "space": {
      "xs": { "$type": "dimension", "$value": { "value": 4, "unit": "px" } },
      "sm": { "$type": "dimension", "$value": { "value": 8, "unit": "px" } },
      "md": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
      "lg": { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "xl": { "$type": "dimension", "$value": { "value": 32, "unit": "px" } }
    },
    "radius": {
      "sm": { "$type": "dimension", "$value": { "value": 4, "unit": "px" } },
      "md": { "$type": "dimension", "$value": { "value": 8, "unit": "px" } }
    },
    "font": {
      "size": {
        "sm":  { "$type": "dimension", "$value": { "value": 14, "unit": "px" } },
        "md":  { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
        "lg":  { "$type": "dimension", "$value": { "value": 20, "unit": "px" } }
      }
    }
  },

  "$elements": {
    "heading": {
      "type": "text",
      "params": ["text"],
      "content": { "$bind": "text" },
      "fontSize": "{font.size.lg}",
      "color": "{color.neutral.900}",
      "fontWeight": "bold"
    },
    "paragraph": {
      "type": "text",
      "params": ["text"],
      "content": { "$bind": "text" },
      "fontSize": "{font.size.md}",
      "color": "{color.neutral.700}"
    },
    "primaryButton": {
      "type": "button",
      "params": ["label"],
      "content": { "$bind": "label" },
      "background": "{color.brand.500}",
      "color": "{color.neutral.50}",
      "padding": "{space.md}",
      "borderRadius": "{radius.md}",
      "fontSize": "{font.size.md}"
    },
    "dangerButton": {
      "type": "button",
      "params": ["label"],
      "content": { "$bind": "label" },
      "background": "{color.danger.500}",
      "color": "{color.neutral.50}",
      "padding": "{space.md}",
      "borderRadius": "{radius.md}",
      "fontSize": "{font.size.md}"
    },
    "textInput": {
      "type": "input",
      "params": ["name", "label", "placeholder"],
      "inputType": "text",
      "aria": { "label": ["param", "label"] },
      "placeholder": ["param", "placeholder"],
      "padding": "{space.sm}",
      "borderRadius": "{radius.sm}",
      "fontSize": "{font.size.md}"
    }
  },

  "$machine": {
    "id": "design-system",
    "initial": "idle",
    "states": {
      "idle": {
        "$visual": {
          "$description": "Design system has no active machine — it exists solely to export tokens and elements."
        }
      }
    }
  }
}
