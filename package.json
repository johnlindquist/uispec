{
  "name": "uxspec",
  "version": "0.2.2",
  "description": "UXSpec — unified state machine + visual specification for AI agents",
  "type": "module",
  "main": "./dist/compile.js",
  "types": "./dist/compile.d.ts",
  "exports": {
    ".": {
      "import": "./dist/compile.js",
      "types": "./dist/compile.d.ts"
    }
  },
  "bin": {
    "uxspec": "bin/uxspec.mjs"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "bin",
    "logo.png"
  ],
  "scripts": {
    "build": "tsup src/compiler/cli.ts src/compiler/compile.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "bun test",
    "validate": "bun run src/compiler/cli.ts validate",
    "compile": "bun run src/compiler/cli.ts compile"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "uxspec",
    "state-machine",
    "ui-specification",
    "design-system",
    "ai-agents",
    "compiler"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
